---
interface Props {
  variant?: 'inline' | 'hero' | 'banner';
  heading?: string;
  subheading?: string;
}

const { variant = 'inline', heading = 'Get the Weekly AI-in-Ed Briefing', subheading = 'One tool review, one policy tip, one action step — every Tuesday. Join 2,500+ school leaders.' } = Astro.props;
---

<div class:list={[
  'rounded-xl',
  variant === 'hero' && 'bg-neutral-900 text-white p-8 md:p-12',
  variant === 'banner' && 'bg-brand-50 border border-brand-100 p-6',
  variant === 'inline' && 'bg-surface-50 border border-neutral-100 p-6',
]} x-data="{ email: '', submitted: false, error: '', loading: false }">

  <div class="max-w-md mx-auto" x-show="!submitted" x-transition>
    <h3 class:list={[
      'font-semibold',
      variant === 'hero' ? 'text-xl text-white' : 'text-lg text-neutral-900',
    ]}>{heading}</h3>

    <p class:list={[
      'mt-2 text-sm leading-relaxed',
      variant === 'hero' ? 'text-neutral-400' : 'text-neutral-500',
    ]}>{subheading}</p>

    <form
      class="mt-5 flex gap-2"
      @submit.prevent="
        error = '';
        if (!email) { error = 'Please enter your email'; return; }
        loading = true;
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });
          if (res.ok) { submitted = true; }
          else { const d = await res.json(); error = d.error || 'Something went wrong'; }
        } catch(e) { error = 'Network error'; }
        loading = false;
      "
    >
      <input
        type="email"
        x-model="email"
        placeholder="you@school.edu"
        required
        class:list={[
          'flex-1 px-3.5 py-2.5 rounded-lg text-sm focus:outline-none focus:ring-2',
          variant === 'hero'
            ? 'bg-white/10 border border-white/10 text-white placeholder-neutral-500 focus:ring-white/20'
            : 'border border-neutral-200 text-neutral-900 placeholder-neutral-400 focus:ring-brand-600 focus:border-transparent',
        ]}
      />
      <button
        type="submit"
        :disabled="loading"
        class:list={[
          'btn shrink-0',
          variant === 'hero'
            ? 'bg-white text-neutral-900 hover:bg-neutral-100'
            : 'bg-brand-600 text-white hover:bg-brand-700',
        ]}
      >
        <span x-show="!loading">Subscribe</span>
        <span x-show="loading">...</span>
      </button>
    </form>

    <p x-show="error" x-text="error" x-transition class="mt-2 text-xs text-red-400"></p>
    <p class:list={['mt-2.5 text-[11px]', variant === 'hero' ? 'text-neutral-500' : 'text-neutral-400']}>No spam. Unsubscribe anytime.</p>
  </div>

  <div x-show="submitted" x-transition class="text-center py-4 max-w-md mx-auto">
    <p class:list={['font-semibold', variant === 'hero' ? 'text-white' : 'text-neutral-900']}>You're in!</p>
    <p class:list={['mt-1 text-sm', variant === 'hero' ? 'text-neutral-400' : 'text-neutral-500']}>Check your inbox for a welcome email.</p>
  </div>
</div>
