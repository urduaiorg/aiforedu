---
interface Props {
  variant?: 'inline' | 'hero' | 'banner';
  heading?: string;
  subheading?: string;
}

const { variant = 'inline', heading = 'Get the Weekly AI-in-Ed Briefing', subheading = 'One tool review, one policy tip, and one action step for school leadership teams every Tuesday.' } = Astro.props;
---

<div class:list={[
  variant === 'hero' && 'cta-panel-dark',
  variant === 'banner' && 'cta-panel',
  variant === 'inline' && 'editorial-panel',
]} x-data="{ email: '', submitted: false, error: '', loading: false, successTitle: 'Subscription confirmed', successMessage: 'Check your inbox for the first briefing and welcome resources.' }">
  <div class="max-w-md mx-auto" x-show="!submitted" x-transition>
    <p class:list={['section-label', variant === 'hero' ? 'text-brand-200' : 'text-ink-400']}>Weekly intelligence brief</p>
    <h3 class:list={[
      'mt-3 font-display text-display-xs',
      variant === 'hero' ? 'text-white' : 'text-ink-950',
    ]}>{heading}</h3>

    <p class:list={[
      'mt-3 text-sm leading-7',
      variant === 'hero' ? 'text-ink-200' : 'text-ink-500',
    ]}>{subheading}</p>

    <form
      class="mt-6 space-y-3"
      @submit.prevent="
        error = '';
        if (!email) { error = 'Please enter your email'; return; }
        loading = true;
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, useCase: 'weekly-briefing' })
          });
          if (res.ok) {
            const d = await res.json();
            successTitle = d.successTitle || successTitle;
            successMessage = d.successMessage || successMessage;
            submitted = true;
          }
          else { const d = await res.json(); error = d.error || 'Something went wrong'; }
        } catch(e) { error = 'Network error'; }
        loading = false;
      "
    >
      <div class="flex flex-col gap-3 sm:flex-row">
        <input
          type="email"
          x-model="email"
          placeholder="you@school.edu"
          required
          class:list={[
            'flex-1',
            variant === 'hero'
              ? 'w-full rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/45 focus:border-white/30 focus:outline-none focus:ring-2 focus:ring-white/15'
              : 'input',
          ]}
        />
        <button
          type="submit"
          :disabled="loading"
          class:list={[
            'shrink-0 justify-center',
            variant === 'hero' ? 'btn-secondary' : 'btn-primary',
          ]}
        >
          <span x-show="!loading">Subscribe</span>
          <span x-show="loading">Working...</span>
        </button>
      </div>

      <p x-show="error" x-text="error" x-transition class:list={['text-xs', variant === 'hero' ? 'text-red-200' : 'text-red-600']}></p>
      <div class="flex flex-wrap gap-3 text-[11px] uppercase tracking-[0.16em]">
        <span class:list={[variant === 'hero' ? 'text-ink-300' : 'text-ink-400']}>No spam</span>
        <span class:list={[variant === 'hero' ? 'text-ink-500' : 'text-paper-300']}>•</span>
        <span class:list={[variant === 'hero' ? 'text-ink-300' : 'text-ink-400']}>Unsubscribe anytime</span>
      </div>
    </form>
  </div>

  <div x-show="submitted" x-transition class="text-center py-4 max-w-md mx-auto">
    <p class:list={['section-label', variant === 'hero' ? 'text-brand-200' : 'text-ink-400']}>Subscription confirmed</p>
    <p class:list={['mt-3 font-display text-display-xs', variant === 'hero' ? 'text-white' : 'text-ink-950']} x-text="successTitle">You are in.</p>
    <p class:list={['mt-2 text-sm leading-7', variant === 'hero' ? 'text-ink-200' : 'text-ink-500']} x-text="successMessage">Check your inbox for the first briefing and welcome resources.</p>
  </div>
</div>
