---
---

<div x-data="{ open: false }" @keydown.window.meta.k.prevent="open = true" @keydown.window.ctrl.k.prevent="open = true">
  <button @click="open = true" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 transition-colors bg-white border border-gray-200 rounded-lg px-3 py-1.5">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <span class="hidden sm:inline">Search...</span>
    <kbd class="hidden sm:inline text-xs bg-gray-100 px-1.5 py-0.5 rounded">⌘K</kbd>
  </button>

  <div x-show="open" x-transition.opacity @click.away="open = false" @keydown.escape.window="open = false"
       class="fixed inset-0 z-[100] flex items-start justify-center pt-[15vh] bg-black/50 backdrop-blur-sm">
    <div @click.stop class="bg-white rounded-xl shadow-2xl w-full max-w-xl mx-4 overflow-hidden">
      <div id="search-container" class="p-4"></div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('search-container');
    if (container && window.PagefindUI) {
      new window.PagefindUI({ element: container, showSubResults: true });
    }
  });
</script>
