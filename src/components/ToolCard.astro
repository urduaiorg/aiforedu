---
interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  pricing: string;
  rating: number;
  ferpaCompliant: boolean;
  bestFor: string;
  featured?: boolean;
}

const { title, slug, description, category, pricing, rating, ferpaCompliant, bestFor, featured } = Astro.props;

const fullStars = Math.round(rating);
const emptyStars = 5 - fullStars;

const pricingMap: Record<string, string> = {
  free: 'tag-green',
  freemium: 'tag-blue',
  paid: 'tag-amber',
};

const categoryLabels: Record<string, string> = {
  'writing': 'Writing',
  'grading': 'Grading',
  'lesson-planning': 'Lesson Planning',
  'admin': 'Admin',
  'student-facing': 'Student',
  'special-ed': 'Special Ed',
};
---

<a href={`/tools/${slug}/`} class="group block card">
  <div class="flex items-center justify-between gap-3 mb-3">
    <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-neutral-400">{categoryLabels[category] || category}</span>
    <span class:list={[pricingMap[pricing] || 'tag', 'shrink-0']}>{pricing}</span>
  </div>

  <h3 class="font-semibold text-base text-neutral-900 group-hover:text-brand-600 transition-colors leading-snug">{title}</h3>
  <p class="mt-1.5 text-sm text-neutral-500 line-clamp-2 leading-relaxed">{description}</p>

  <div class="mt-4 pt-3 border-t border-neutral-100 flex items-center justify-between gap-3">
    <div class="flex items-center gap-1" title={`${rating}/5`}>
      {Array.from({ length: fullStars }).map(() => (
        <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      ))}
      {Array.from({ length: emptyStars }).map(() => (
        <svg class="w-3.5 h-3.5 text-neutral-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      ))}
      <span class="text-[11px] text-neutral-400 ml-1 font-medium">{rating}</span>
    </div>
    <div class="flex items-center gap-2">
      {ferpaCompliant && <span class="tag-green">FERPA</span>}
    </div>
  </div>
</a>
