---
interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  pricing: string;
  rating: number;
  ferpaCompliant: boolean;
  bestFor: string;
  featured?: boolean;
}

const { title, slug, description, category, pricing, rating, ferpaCompliant, bestFor, featured } = Astro.props;

const fullStars = Math.round(rating);
const emptyStars = 5 - fullStars;

const pricingMap: Record<string, string> = {
  free: 'tag-green',
  freemium: 'tag-blue',
  paid: 'tag-amber',
};

const categoryLabels: Record<string, string> = {
  'writing': 'Writing',
  'grading': 'Grading',
  'lesson-planning': 'Lesson Planning',
  'admin': 'Admin',
  'student-facing': 'Student',
  'special-ed': 'Special Ed',
};
---

<a href={`/tools/${slug}/`} class="group block card">
  <div class="flex items-center justify-between gap-3">
    <span class="label">{categoryLabels[category] || category}</span>
    <span class:list={[pricingMap[pricing] || 'tag', 'shrink-0']}>{pricing}</span>
  </div>

  <h3 class="mt-4 font-display text-[1.55rem] leading-tight text-ink-950 group-hover:text-brand-700">{title}</h3>
  <p class="mt-3 line-clamp-3 text-sm leading-7 text-ink-500">{description}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    <span class="badge-blue">Best for {bestFor}</span>
    {featured && <span class="badge-ink">Featured review</span>}
  </div>

  <div class="surface-rule mt-6 flex items-center justify-between gap-3 pt-4">
    <div class="flex items-center gap-1" title={`${rating}/5`}>
      {Array.from({ length: fullStars }).map((_, index) => (
        <svg class="h-3.5 w-3.5 text-gold-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" key={index}><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      ))}
      {Array.from({ length: emptyStars }).map((_, index) => (
        <svg class="h-3.5 w-3.5 text-paper-300" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" key={index}><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      ))}
      <span class="ml-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-400">{rating}/5</span>
    </div>
    <div class="flex items-center gap-2 text-sm text-ink-500">
      {ferpaCompliant && <span class="tag-green">FERPA</span>}
      <span class="btn-quiet text-xs uppercase tracking-[0.18em]">Review</span>
    </div>
  </div>
</a>
