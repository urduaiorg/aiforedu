---
interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  pricing: string;
  rating: number;
  ferpaCompliant: boolean;
  bestFor: string;
  featured?: boolean;
}

const { title, slug, description, category, pricing, rating, ferpaCompliant, bestFor, featured } = Astro.props;

const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
const pricingColors: Record<string, string> = { free: 'badge-green', freemium: 'badge-blue', paid: 'badge-yellow' };
---

<a href={`/tools/${slug}/`} class:list={['card group block', featured && 'ring-2 ring-primary-500']}>
  {featured && <span class="badge-blue mb-3 text-xs">Featured</span>}
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-display font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">{title}</h3>
    <span class:list={[pricingColors[pricing] || 'badge', 'shrink-0']}>{pricing}</span>
  </div>
  <p class="mt-2 text-sm text-gray-600 line-clamp-2">{description}</p>
  <div class="mt-4 flex items-center gap-4 text-sm">
    <span class="text-yellow-500" title={`${rating}/5`}>{stars}</span>
    {ferpaCompliant && <span class="badge-green">FERPA ✓</span>}
  </div>
  <p class="mt-2 text-xs text-gray-500">Best for: {bestFor}</p>
</a>
