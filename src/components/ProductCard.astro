---
interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  href: string;
  badge?: string;
  popular?: boolean;
}
const { title, price, description, features, href, badge, popular } = Astro.props;
---

<div class:list={[
  'flex flex-col h-full rounded-xl border p-6 transition-shadow duration-200',
  popular
    ? 'bg-neutral-900 text-white border-neutral-800 shadow-mockup-sm'
    : 'bg-white border-neutral-200/60 shadow-card hover:shadow-card-hover',
]}>
  {badge && (
    <span class:list={[
      'self-start text-[10px] font-semibold uppercase tracking-[0.12em] mb-4',
      popular ? 'text-brand-200' : 'text-brand-600',
    ]}>{badge}</span>
  )}

  <h3 class:list={['font-semibold text-lg', popular ? 'text-white' : 'text-neutral-900']}>{title}</h3>

  <div class="mt-2 flex items-baseline gap-1.5">
    <span class:list={['text-3xl font-extrabold tracking-tight', popular ? 'text-white' : 'text-neutral-900']}>{price}</span>
    <span class:list={['text-xs', popular ? 'text-neutral-400' : 'text-neutral-400']}>one-time</span>
  </div>

  <p class:list={['mt-3 text-sm flex-1 leading-relaxed', popular ? 'text-neutral-300' : 'text-neutral-500']}>{description}</p>

  <div class:list={['my-5 h-px', popular ? 'bg-neutral-700' : 'bg-neutral-100']}></div>

  <ul class="space-y-2.5">
    {features.map(f => (
      <li class="flex items-start gap-2 text-sm">
        <svg class:list={['w-4 h-4 shrink-0 mt-0.5', popular ? 'text-brand-300' : 'text-emerald-500']} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span class:list={[popular ? 'text-neutral-300' : 'text-neutral-600']}>{f}</span>
      </li>
    ))}
  </ul>

  <a
    href={href}
    class:list={[
      'mt-6 btn justify-center w-full',
      popular
        ? 'bg-white text-neutral-900 hover:bg-neutral-100'
        : 'bg-neutral-900 text-white hover:bg-neutral-800',
    ]}
  >Get Access</a>
</div>
