---
interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  href: string;
  badge?: string;
  popular?: boolean;
}
const { title, price, description, features, href, badge, popular } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
---

<div class:list={[
  'flex h-full flex-col rounded-[1.75rem] border p-7 transition-all duration-200',
  popular
    ? 'border-ink-800 bg-ink-950 text-white shadow-panel-lg'
    : 'border-paper-300/90 bg-white/90 shadow-panel hover:-translate-y-1 hover:shadow-panel-lg',
]}>
  {badge && (
    <span class:list={[
      'self-start rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] mb-5',
      popular ? 'border-brand-300/20 bg-brand-400/10 text-brand-100' : 'border-paper-300 bg-paper-50 text-ink-500',
    ]}>{badge}</span>
  )}

  <div class="flex items-start justify-between gap-4">
    <h3 class:list={['font-display text-[1.8rem] leading-tight', popular ? 'text-white' : 'text-ink-950']}>{title}</h3>
    <span class:list={['label shrink-0', popular ? 'text-brand-200' : 'text-ink-400']}>Toolkit</span>
  </div>

  <div class="mt-4 flex items-end gap-2">
    <span class:list={['font-display text-display-xs', popular ? 'text-white' : 'text-ink-950']}>{price}</span>
    <span class:list={['pb-1 text-xs uppercase tracking-[0.16em]', popular ? 'text-ink-300' : 'text-ink-400']}>One-time</span>
  </div>

  <p class:list={['mt-4 flex-1 text-sm leading-7', popular ? 'text-ink-200' : 'text-ink-500']}>{description}</p>

  <div class:list={['my-6 h-px', popular ? 'bg-ink-800' : 'bg-paper-300']}></div>

  <ul class="space-y-2.5">
    {features.map(f => (
      <li class="flex items-start gap-2 text-sm">
        <svg class:list={['mt-0.5 h-4 w-4 shrink-0', popular ? 'text-brand-300' : 'text-sage-600']} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span class:list={[popular ? 'text-ink-200' : 'text-ink-600']}>{f}</span>
      </li>
    ))}
  </ul>

  <a
    href={href}
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'noopener' : undefined}
    class:list={[
      'mt-7 w-full justify-center',
      popular
        ? 'btn-secondary'
        : 'btn-primary',
    ]}
  >{isExternal ? 'Go to checkout' : 'See details'}</a>
</div>
