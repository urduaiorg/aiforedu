---
interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  href: string;
  badge?: string;
  popular?: boolean;
}
const { title, price, description, features, href, badge, popular } = Astro.props;
---

<div class:list={[
  'relative flex flex-col h-full rounded-2xl border p-7 transition-all duration-300 ease-out',
  popular
    ? 'bg-white border-primary-200 ring-2 ring-primary-100 shadow-elevated scale-[1.02] hover:shadow-glow'
    : 'bg-white border-gray-100 shadow-card hover:shadow-card-hover hover:-translate-y-1',
]}>
  {badge && (
    <div class="absolute -top-3 left-6">
      <span class:list={[
        'inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold shadow-sm',
        popular ? 'bg-primary-600 text-white' : 'badge-blue',
      ]}>
        {popular && (
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        )}
        {badge}
      </span>
    </div>
  )}

  <h3 class="font-bold text-xl text-gray-900 mt-1">{title}</h3>

  <div class="mt-3 flex items-baseline gap-1">
    <span class="text-4xl font-extrabold tracking-tight text-gray-900">{price}</span>
    <span class="text-sm text-gray-400 font-medium">one-time</span>
  </div>

  <p class="mt-4 text-sm text-gray-500 leading-relaxed flex-1">{description}</p>

  <div class="mt-6 h-px bg-gray-100"></div>

  <ul class="mt-5 space-y-3">
    {features.map(f => (
      <li class="flex items-start gap-2.5 text-sm text-gray-700">
        <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>{f}</span>
      </li>
    ))}
  </ul>

  <a
    href={href}
    class:list={[
      'mt-7 inline-flex items-center justify-center gap-2 w-full py-3 px-6 rounded-xl font-medium text-sm transition-all duration-200 ease-out',
      popular
        ? 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0'
        : 'bg-gray-900 text-white hover:bg-gray-800 hover:-translate-y-0.5 active:translate-y-0',
    ]}
  >
    Get Instant Access
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </a>
</div>
