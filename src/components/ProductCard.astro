---
interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  href: string;
  badge?: string;
}
const { title, price, description, features, href, badge } = Astro.props;
---

<div class="card flex flex-col h-full">
  {badge && <span class="badge-blue self-start mb-3">{badge}</span>}
  <h3 class="font-display font-bold text-xl text-gray-900">{title}</h3>
  <p class="text-3xl font-bold text-primary-600 mt-2">{price}</p>
  <p class="mt-3 text-sm text-gray-600 flex-1">{description}</p>
  <ul class="mt-4 space-y-2">
    {features.map(f => (
      <li class="flex items-start gap-2 text-sm text-gray-700">
        <span class="text-accent-500 mt-0.5">✓</span>
        <span>{f}</span>
      </li>
    ))}
  </ul>
  <a href={href} class="btn-primary mt-6 justify-center w-full">Get Instant Access</a>
</div>
