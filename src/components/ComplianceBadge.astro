---
interface Props {
  ferpa: boolean;
  coppa: boolean;
  size?: 'sm' | 'md';
}
const { ferpa, coppa, size = 'sm' } = Astro.props;
const cls = size === 'sm' ? 'text-xs px-3 py-1' : 'text-sm px-3.5 py-1.5';
---

<div class="flex gap-2 flex-wrap">
  {ferpa && <span class:list={['rounded-full border font-medium uppercase tracking-[0.14em]', cls, 'border-sage-100 bg-sage-50 text-sage-700']}>FERPA cleared</span>}
  {coppa && <span class:list={['rounded-full border font-medium uppercase tracking-[0.14em]', cls, 'border-brand-100 bg-brand-50 text-brand-700']}>COPPA cleared</span>}
  {!ferpa && <span class:list={['rounded-full border font-medium uppercase tracking-[0.14em]', cls, 'border-red-200 bg-red-50 text-red-700']}>FERPA review needed</span>}
</div>
