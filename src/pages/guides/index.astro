---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const guides = await getCollection('guides');
const sorted = guides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Implementation Guides" description="Step-by-step guides for bringing AI into your school responsibly.">
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <p class="eyebrow">Implementation guides</p>
      <h1 class="mt-6 page-title">How to move from experimentation to institutional practice.</h1>
      <p class="page-lede">Practical guidance for leaders shaping rollout, governance, communication, and district readiness.</p>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {sorted.map(g => (
          <a href={`/guides/${g.slug}/`} class="group index-card">
            <span class="badge-blue">{g.data.category}</span>
            <h3 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{g.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink-500">{g.data.description}</p>
            <p class="mt-5 label">{g.data.readTime} minute read</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
