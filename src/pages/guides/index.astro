---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const sorted = guides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Implementation Guides" description="Step-by-step guides for bringing AI into your school responsibly.">
  <section class="py-12">
    <div class="container-wide">
      <h1 class="font-display text-4xl font-bold text-gray-900">Implementation Guides</h1>
      <p class="mt-3 text-lg text-gray-600 max-w-2xl">Practical, step-by-step resources for school leaders implementing AI initiatives.</p>
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map(g => (
          <a href={`/guides/${g.slug}/`} class="card group">
            <span class="badge-blue mb-3">{g.data.category}</span>
            <h3 class="font-display font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">{g.data.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{g.data.description}</p>
            <p class="mt-3 text-xs text-gray-400">{g.data.readTime} min read</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
