---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { products } from '../../data/products';
import { productAssurances } from '../../data/editorial';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';

export const prerender = true;

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const checkoutPath = `/api/products/${product.slug}?source=product-page-${product.slug}`;
const structuredData = [
  breadcrumbSchema([
    { name: 'Home', url: 'https://aiforedu.ai/' },
    { name: 'Premium resources', url: 'https://aiforedu.ai/products/' },
    { name: product.title, url: `https://aiforedu.ai/products/${product.slug}/` },
  ]),
  faqSchema(product.faq),
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.title,
    description: product.description,
    brand: {
      '@type': 'Brand',
      name: 'AIForEdu',
    },
    offers: {
      '@type': 'Offer',
      price: product.price.replace('$', ''),
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      url: `https://aiforedu.ai/products/${product.slug}/`,
    },
  },
];
---

<BaseLayout title={product.title} description={product.description} ogType="product" structuredData={structuredData}>
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span class="divider-dot"></span>
        <a href="/products/">Premium resources</a>
        <span class="divider-dot"></span>
        <span>{product.title}</span>
      </nav>

      <div class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-end">
        <div>
          <p class="eyebrow">Premium resource</p>
          <h1 class="mt-6 page-title">{product.title}</h1>
          <p class="page-lede">{product.description}</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <span class="badge-blue">{product.shortLabel}</span>
            <span class="badge-yellow">{product.price} one-time</span>
            {product.badge && <span class="badge-green">{product.badge}</span>}
          </div>
        </div>

        <div class="editorial-panel">
          <p class="label">Outcome</p>
          <p class="mt-3 font-display text-display-xs text-ink-950">{product.promise}</p>
          <a href={checkoutPath} class="btn-primary mt-6 w-full justify-center">Go to checkout</a>
          <p class="small-note mt-3">Checkout is handled via LemonSqueezy. Delivery is digital and immediate after purchase.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <div class="space-y-6">
          <div class="article-frame">
            <p class="section-label">Who this is for</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">Designed for working leadership teams.</h2>
            <p class="mt-3 text-base leading-8 text-ink-500">{product.audience}</p>
          </div>

          <div class="article-frame">
            <p class="section-label">What is included</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">What your team gets.</h2>
            <div class="mt-5 grid gap-4 md:grid-cols-2">
              {product.features.map((feature) => (
                <div class="info-card">
                  <p class="value">{feature}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="article-frame">
            <p class="section-label">See inside</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">What the working files actually help you do.</h2>
            <div class="mt-5 grid gap-4 md:grid-cols-3">
              {product.preview.map((item) => (
                <div class="info-card">
                  <p class="value">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="article-frame">
            <p class="section-label">Deliverables</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">The files and artifacts included in the bundle.</h2>
            <div class="mt-5 grid gap-4 md:grid-cols-2">
              {product.deliverables.map((item) => (
                <div class="info-card">
                  <p class="value">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="article-frame">
            <p class="section-label">What changes after purchase</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">Why teams buy this instead of building from scratch.</h2>
            <div class="mt-5 grid gap-4 md:grid-cols-3">
              {product.outcomes.map((outcome) => (
                <div class="info-card">
                  <p class="value">{outcome}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="article-frame">
            <p class="section-label">FAQ</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">Common purchase questions.</h2>
            <div class="mt-5 space-y-4">
              {product.faq.map((entry) => (
                <div class="info-card">
                  <h3 class="value">{entry.question}</h3>
                  <p class="mt-3 text-sm leading-7 text-ink-500">{entry.answer}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <aside class="article-rail">
          <div class="article-rail-card">
            <p class="label">Purchase summary</p>
            <p class="mt-3 text-sm leading-7 text-ink-500">{product.price} one-time purchase with delivery handled through LemonSqueezy checkout.</p>
            <a href={checkoutPath} class="btn-primary mt-5 w-full justify-center">Go to checkout</a>
            <div class="mt-5 space-y-3">
              <div class="info-card">
                <p class="label">Delivery</p>
                <p class="mt-2 text-sm leading-7 text-ink-500">{product.delivery}</p>
              </div>
              <div class="info-card">
                <p class="label">Format</p>
                <p class="mt-2 text-sm leading-7 text-ink-500">{product.format}</p>
              </div>
              <div class="info-card">
                <p class="label">License</p>
                <p class="mt-2 text-sm leading-7 text-ink-500">{product.license}</p>
              </div>
            </div>
          </div>
          <div class="article-rail-card">
            <p class="label">Buyer reassurance</p>
            <div class="mt-4 space-y-3">
              {productAssurances.map((item) => (
                <div class="info-card">
                  <p class="value">{item}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="article-rail-card">
            <p class="label">Alternative path</p>
            <p class="mt-3 text-sm leading-7 text-ink-500">Still evaluating your governance approach? Start with the free policy template before choosing a toolkit.</p>
            <a href="/downloads/ai-policy-template/" class="btn-secondary mt-5 w-full justify-center">See the free starter</a>
          </div>
        </aside>
      </div>

      <div class="mt-10">
        <NewsletterSignup
          variant="banner"
          heading="Prefer to research first?"
          subheading="Get the weekly briefing and return when your team is ready to move from exploration to purchase."
        />
      </div>
    </div>
  </section>
</BaseLayout>
