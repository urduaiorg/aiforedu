---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
---

<BaseLayout title="Premium Resources" description="Ready-to-implement AI toolkits for K-12 school leaders. Policy kits, readiness workbooks, and tool vetting packs.">
  <section class="py-12">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto">
        <h1 class="font-display text-4xl font-bold text-gray-900">Premium Resources</h1>
        <p class="mt-3 text-lg text-gray-600">Save weeks of work with our ready-to-implement toolkits. Each product is vetted by education consultants and updated quarterly.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <ProductCard
          title="AI Policy Kit"
          price="$29"
          badge="Best Seller"
          description="Complete policy bundle for district-wide AI adoption. Board-ready from day one."
          features={['5 editable policy templates (Word)', 'Board presentation deck (PPT)', 'Parent communication letter', 'Staff training checklist', 'FERPA/COPPA compliance matrix', 'Quarterly update emails']}
          href="https://aiforedu.lemonsqueezy.com/checkout/policy-kit"
        />
        <ProductCard
          title="AI Readiness Workbook"
          price="$19"
          description="Self-assessment and planning tool for AI integration readiness."
          features={['Infrastructure audit checklist', '90-day implementation timeline', 'Budget planning worksheet', 'Stakeholder survey templates', 'Progress tracking dashboard', 'PD session outlines']}
          href="https://aiforedu.lemonsqueezy.com/checkout/readiness-workbook"
        />
        <ProductCard
          title="Tool Vetting Pack"
          price="$39"
          badge="Most Comprehensive"
          description="Everything you need to evaluate and approve AI tools for your district."
          features={['Vendor evaluation rubric', 'Security questionnaire template', 'Pilot program framework', '50+ pre-vetted tool profiles', 'Comparison spreadsheet', 'Board recommendation template']}
          href="https://aiforedu.lemonsqueezy.com/checkout/tool-vetting-pack"
        />
      </div>

      <div class="mt-16 bg-gray-100 rounded-xl p-8 text-center max-w-2xl mx-auto">
        <h3 class="font-display font-bold text-xl text-gray-900">Not sure where to start?</h3>
        <p class="mt-2 text-gray-600">Download our free AI Policy Template first — no purchase required.</p>
        <a href="/#free-template" class="btn-primary mt-4">Get Free Template</a>
      </div>

      <div class="mt-16">
        <NewsletterSignup variant="hero" />
      </div>
    </div>
  </section>
</BaseLayout>
