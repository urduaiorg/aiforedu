---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export const prerender = true;
---

<BaseLayout title="Premium Resources" description="Ready-to-implement AI toolkits for K-12 school leaders. Policy kits, readiness workbooks, and tool vetting packs.">
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <div class="max-w-3xl">
        <p class="eyebrow">Premium resource catalog</p>
        <h1 class="mt-6 page-title">Done-for-you assets for teams that need operational speed.</h1>
        <p class="page-lede">These toolkits are designed for leadership teams that want implementation-ready materials, not more blank pages.</p>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <ProductCard
          title="AI Policy Kit"
          price="$29"
          badge="Best Seller"
          popular={true}
          description="Complete policy bundle for district-wide AI adoption. Board-ready from day one."
          features={['5 editable policy templates (Word)', 'Board presentation deck (PPT)', 'Parent communication letter', 'Staff training checklist', 'FERPA/COPPA compliance matrix']}
          href="/products/policy-kit/"
        />
        <ProductCard
          title="AI Readiness Workbook"
          price="$19"
          description="Self-assessment and planning tool for AI integration readiness."
          features={['Infrastructure audit checklist', '90-day implementation timeline', 'Budget planning worksheet', 'Stakeholder survey templates', 'Progress tracking dashboard', 'PD session outlines']}
          href="/products/readiness-workbook/"
        />
        <ProductCard
          title="Tool Vetting Pack"
          price="$39"
          badge="Most Comprehensive"
          description="Everything you need to evaluate and approve AI tools for your district."
          features={['Vendor evaluation rubric', 'Security questionnaire template', 'Pilot program framework', 'Tool profile tracker', 'Comparison spreadsheet', 'Board recommendation template']}
          href="/products/tool-vetting-pack/"
        />
      </div>

      <div class="cta-panel mt-12 max-w-3xl">
        <p class="section-label">Not sure where to start?</p>
        <h2 class="mt-3 font-display text-display-xs text-ink-950">Begin with the free policy template.</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-500">If your team is still framing governance and board language, the free policy template is the best first step before purchasing any toolkit.</p>
        <a href="/#free-template" class="btn-primary mt-5">Get the free template</a>
      </div>

      <div class="mt-12">
        <NewsletterSignup variant="hero" />
      </div>
    </div>
  </section>
</BaseLayout>
