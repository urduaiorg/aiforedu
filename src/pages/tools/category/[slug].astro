---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { toolCategoryMeta, toolCategoryOrder, type ToolCategorySlug } from '../../../data/toolCategories';
import { breadcrumbSchema } from '../../../lib/schema';

export const prerender = true;

export async function getStaticPaths() {
  return toolCategoryOrder.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: ToolCategorySlug };
const category = toolCategoryMeta[slug];
const allTools = await getCollection('tools');
const tools = allTools
  .filter((tool) => tool.data.category === slug)
  .sort((a, b) => b.data.rating - a.data.rating);

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', url: 'https://aiforedu.ai/' },
    { name: 'Tool reviews', url: 'https://aiforedu.ai/tools/' },
    { name: category.label, url: `https://aiforedu.ai/tools/category/${slug}/` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${category.label} AI tool reviews`,
    url: `https://aiforedu.ai/tools/category/${slug}/`,
    description: category.description,
    about: category.audienceQuestion,
  },
];
---

<BaseLayout
  title={`${category.label} AI Tools`}
  description={`${category.description} ${category.audienceQuestion}`}
  structuredData={structuredData}
>
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span class="divider-dot"></span>
        <a href="/tools/">Tool reviews</a>
        <span class="divider-dot"></span>
        <span>{category.label}</span>
      </nav>

      <div class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
        <div>
          <p class="eyebrow">{category.shortLabel}</p>
          <h1 class="mt-6 page-title">{category.label} reviews for educators and institutions.</h1>
          <p class="page-lede">{category.description}</p>
          <p class="mt-4 max-w-2xl text-base leading-8 text-ink-500">{category.audienceQuestion}</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Coverage in this category</p>
          <p class="mt-3 font-display text-display-xs text-ink-950">{tools.length}</p>
          <p class="mt-2 text-sm leading-7 text-ink-500">Current reviews, each with ratings, pricing context, and implementation notes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="mb-8 flex flex-wrap gap-3">
        <a href="/tools/" class="btn-secondary">All reviews</a>
        <a href="/methodology/" class="btn-secondary">Methodology</a>
      </div>
      {tools.length > 0 ? (
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
          {tools.map((tool) => (
            <ToolCard
              title={tool.data.title}
              slug={tool.slug}
              description={tool.data.description}
              category={tool.data.category}
              pricing={tool.data.pricing}
              rating={tool.data.rating}
              ferpaCompliant={tool.data.ferpaCompliant}
              bestFor={tool.data.bestFor}
              featured={tool.data.featured}
            />
          ))}
        </div>
      ) : (
        <div class="cta-panel">
          <p class="section-label">Coverage expanding</p>
          <h2 class="mt-3 font-display text-display-xs text-ink-950">This category is being built out next.</h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-500">
            AIForEdu is expanding coverage here as part of the wider educators-and-institutions roadmap. Until then, browse the broader library or join the newsletter for updates.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/tools/" class="btn-secondary">Browse all reviews</a>
            <a href="/newsletter/" class="btn-primary">Subscribe free</a>
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
