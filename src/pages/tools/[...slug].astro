---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComplianceBadge from '../../components/ComplianceBadge.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({ params: { slug: tool.slug }, props: { tool } }));
}

const { tool } = Astro.props;
const { Content } = await tool.render();
const { title, description, category, pricing, priceRange, rating, ferpaCompliant, coppaCompliant, gradeLevel, bestFor, website, affiliate, lastReviewed, reviewedBy, reviewFrameworkVersion, evidenceLevel, verificationNotes, rubric } = tool.data;

const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
const trackingUrl = affiliate ? `/api/affiliate/${affiliate.slug}` : website;
const suggestedProductHref = '/products/tool-vetting-pack/';
const suggestedProductLabel = 'See the vetting pack';
---

<BaseLayout title={title} description={description}>
  <article class="section-shell-tight">
    <div class="container-full">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span class="divider-dot"></span>
        <a href="/tools/">Tool reviews</a>
        <span class="divider-dot"></span>
        <span>{title}</span>
      </nav>

      <div class="mt-6 article-frame">
        <div class="article-grid">
          <div>
            <p class="section-label">Independent review</p>
            <h1 class="mt-3 page-title">{title}</h1>
            <p class="page-lede">{description}</p>

            <div class="mt-6 flex flex-wrap items-center gap-3">
              <span class="badge-blue capitalize">{pricing}{priceRange ? ` — ${priceRange}` : ''}</span>
              <span class="badge-yellow" title={`${rating}/5`}>{stars} {rating}/5</span>
              <ComplianceBadge ferpa={ferpaCompliant} coppa={coppaCompliant} />
            </div>

            <div class="mt-8 info-grid">
              <div class="info-card">
                <p class="label">Category</p>
                <p class="value capitalize">{category.replace('-', ' ')}</p>
              </div>
              <div class="info-card">
                <p class="label">Best fit</p>
                <p class="value">{bestFor}</p>
              </div>
              <div class="info-card">
                <p class="label">Grade levels</p>
                <p class="value">{gradeLevel.join(', ')}</p>
              </div>
              <div class="info-card">
                <p class="label">Last reviewed</p>
                <p class="value">{lastReviewed.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
              </div>
              <div class="info-card">
                <p class="label">Reviewed by</p>
                <p class="value">{reviewedBy}</p>
              </div>
              <div class="info-card">
                <p class="label">Evidence level</p>
                <p class="value capitalize">{evidenceLevel.replace('-', ' ')}</p>
              </div>
              <div class="info-card">
                <p class="label">Framework</p>
                <p class="value">AIForEdu {reviewFrameworkVersion}</p>
              </div>
            </div>

            <div class="article-frame mt-8">
              <p class="section-label">Score breakdown</p>
              <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <div class="info-card">
                  <p class="label">Privacy</p>
                  <p class="value">{rubric.privacy}/5</p>
                </div>
                <div class="info-card">
                  <p class="label">Instructional value</p>
                  <p class="value">{rubric.instructionalValue}/5</p>
                </div>
                <div class="info-card">
                  <p class="label">Implementation</p>
                  <p class="value">{rubric.implementation}/5</p>
                </div>
                <div class="info-card">
                  <p class="label">Transparency</p>
                  <p class="value">{rubric.transparency}/5</p>
                </div>
              </div>
            </div>

            <div class="article-frame mt-8">
              <p class="section-label">Verification notes</p>
              <div class="mt-5 space-y-4">
                {verificationNotes.map((note) => (
                  <div class="info-card">
                    <p class="value">{note}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="prose-content mt-12">
              <Content />
            </div>
          </div>

          <aside class="article-rail">
            <div class="article-rail-card">
              <p class="label">Vendor access</p>
              <p class="mt-3 text-sm leading-7 text-ink-500">Visit the vendor site when you are ready to evaluate the product in detail.</p>
              <a href={trackingUrl} target="_blank" rel="noopener" class="btn-primary mt-5 w-full justify-center">Visit {title}</a>
            </div>
            <div class="article-rail-card">
              <p class="label">Leadership note</p>
              <p class="mt-3 text-sm leading-7 text-ink-500">Need a stronger procurement process? Use the premium vetting materials to evaluate risk, readiness, and board communication.</p>
              <a href={suggestedProductHref} class="btn-secondary mt-5 w-full justify-center">{suggestedProductLabel}</a>
            </div>
            <div class="article-rail-card">
              <p class="label">Methodology</p>
              <p class="mt-3 text-sm leading-7 text-ink-500">Read how AIForEdu distinguishes vendor claims, document review, and operational observation.</p>
              <a href="/methodology/" class="btn-secondary mt-5 w-full justify-center">Review the method</a>
            </div>
          </aside>
        </div>
      </div>

      <div class="mt-10">
        <NewsletterSignup variant="banner" heading="Get tool reviews like this every week" subheading="Join school leaders who stay ahead with one concise Tuesday briefing." />
      </div>
    </div>
  </article>
</BaseLayout>
