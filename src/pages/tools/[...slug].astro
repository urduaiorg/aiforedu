---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComplianceBadge from '../../components/ComplianceBadge.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({ params: { slug: tool.slug }, props: { tool } }));
}

const { tool } = Astro.props;
const { Content } = await tool.render();
const { title, description, category, pricing, priceRange, rating, ferpaCompliant, coppaCompliant, gradeLevel, bestFor, website, affiliate, lastReviewed } = tool.data;

const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
const trackingUrl = affiliate ? `/api/affiliate/${affiliate.slug}` : website;
---

<BaseLayout title={title} description={description}>
  <article class="py-12">
    <div class="container-narrow">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Home</a> →
        <a href="/tools/" class="hover:text-primary-600">Tool Reviews</a> →
        <span class="text-gray-900">{title}</span>
      </nav>

      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div>
          <h1 class="font-display text-4xl font-bold text-gray-900">{title}</h1>
          <p class="mt-3 text-lg text-gray-600">{description}</p>
          <div class="mt-4 flex flex-wrap items-center gap-3">
            <span class="text-yellow-500 text-lg" title={`${rating}/5`}>{stars} <span class="text-gray-600 text-sm">({rating}/5)</span></span>
            <ComplianceBadge ferpa={ferpaCompliant} coppa={coppaCompliant} />
            <span class="badge-blue capitalize">{pricing}{priceRange ? ` — ${priceRange}` : ''}</span>
          </div>
        </div>
        <a href={trackingUrl} target="_blank" rel="noopener" class="btn-primary shrink-0">
          Visit {title} →
        </a>
      </div>

      <!-- Quick facts -->
      <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Category</p>
          <p class="mt-1 font-semibold text-gray-900 capitalize">{category.replace('-', ' ')}</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Best For</p>
          <p class="mt-1 font-semibold text-gray-900">{bestFor}</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Grade Levels</p>
          <p class="mt-1 font-semibold text-gray-900">{gradeLevel.join(', ')}</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Last Reviewed</p>
          <p class="mt-1 font-semibold text-gray-900">{lastReviewed.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
        </div>
      </div>

      <!-- Content -->
      <div class="mt-12 prose-content">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-primary-50 rounded-xl p-8 text-center">
        <h3 class="font-display text-xl font-bold text-gray-900">Ready to try {title}?</h3>
        <p class="mt-2 text-gray-600">Click below to visit their site. Need help vetting it for your district?</p>
        <div class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
          <a href={trackingUrl} target="_blank" rel="noopener" class="btn-primary">Visit {title}</a>
          <a href="/products/tool-vetting-pack/" class="btn-secondary">Get the Vetting Pack</a>
        </div>
      </div>

      <!-- Newsletter -->
      <div class="mt-12">
        <NewsletterSignup variant="banner" heading="Get tool reviews like this every week" subheading="Join school leaders who stay ahead with our Tuesday AI briefing." />
      </div>
    </div>
  </article>
</BaseLayout>
