---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { toolCategoryMeta, toolCategoryOrder } from '../../data/toolCategories';
import { breadcrumbSchema } from '../../lib/schema';

export const prerender = true;

const allTools = await getCollection('tools');
const tools = allTools.sort((a, b) => b.data.rating - a.data.rating);
const categoryCounts = allTools.reduce((acc, tool) => {
  acc[tool.data.category] = (acc[tool.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const categories = toolCategoryOrder.filter((slug) => categoryCounts[slug]).map((slug) => ({
  slug,
  label: toolCategoryMeta[slug].label,
  count: categoryCounts[slug],
}));
const structuredData = [
  breadcrumbSchema([
    { name: 'Home', url: 'https://aiforedu.ai/' },
    { name: 'Tool reviews', url: 'https://aiforedu.ai/tools/' },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'AI tool reviews for school systems',
    url: 'https://aiforedu.ai/tools/',
    description:
      'Independent reviews of AI tools for K-12 education with emphasis on privacy posture, implementation readiness, and classroom fit.',
  },
];
---

<BaseLayout
  title="AI Tool Reviews"
  description="Independent reviews of AI tools for educators and institutions worldwide, with emphasis on privacy posture, implementation readiness, and classroom fit."
  structuredData={structuredData}
>
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
        <div>
          <p class="eyebrow">Review library</p>
          <h1 class="mt-6 page-title">AI tool reviews for educators and institutions.</h1>
          <p class="page-lede">Every tool is reviewed through the lens of compliance, classroom fit, implementation friction, and educational usefulness.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Current coverage</p>
          <p class="mt-3 font-display text-display-xs text-ink-950">{tools.length}</p>
          <p class="mt-2 text-sm leading-7 text-ink-500">Reviewed tools across the most common K-12 AI categories.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-tight" x-data="{ active: 'all' }">
    <div class="container-full">
      <div class="flex flex-wrap gap-3">
        <button @click="active = 'all'" :class="active === 'all' ? 'filter-chip-active' : ''" class="filter-chip">All tools</button>
        {categories.map((cat) => (
          <button @click={`active = '${cat.slug}'`} x-bind:class={`active === '${cat.slug}' ? 'filter-chip-active' : ''`} class="filter-chip">
            {cat.label}
          </button>
        ))}
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        {categories.map((cat) => (
          <a href={`/tools/category/${cat.slug}/`} class="metric-chip">
            {cat.label}
            <span class="divider-dot"></span>
            {cat.count}
          </a>
        ))}
      </div>

      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {tools.map(tool => (
          <div x-data x-show={`active === 'all' || active === '${tool.data.category}'`} x-transition>
            <ToolCard
              title={tool.data.title}
              slug={tool.slug}
              description={tool.data.description}
              category={tool.data.category}
              pricing={tool.data.pricing}
              rating={tool.data.rating}
              ferpaCompliant={tool.data.ferpaCompliant}
              bestFor={tool.data.bestFor}
              featured={tool.data.featured}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
