---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const policies = await getCollection('policies');
const sorted = policies.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Policy Templates & Guides" description="Free and premium AI policy templates, frameworks, and checklists for K-12 schools.">
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <p class="eyebrow">Governance library</p>
      <h1 class="mt-6 page-title">AI policy resources for schools.</h1>
      <p class="page-lede">Board-ready templates, implementation frameworks, and compliance-oriented guidance for responsible AI adoption.</p>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {sorted.map(p => (
          <a href={`/policy/${p.slug}/`} class="group index-card">
            <div class="flex flex-wrap items-center gap-2">
              <span class="badge-blue capitalize">{p.data.type}</span>
              {p.data.downloadable && <span class="badge-green">Downloadable</span>}
              {p.data.gated && <span class="badge-yellow">Email Required</span>}
            </div>
            <h3 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{p.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink-500">{p.data.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.data.audience.map(a => <span class="metric-chip">{a}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
