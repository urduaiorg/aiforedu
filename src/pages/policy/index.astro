---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const policies = await getCollection('policies');
const sorted = policies.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Policy Templates & Guides" description="Free and premium AI policy templates, frameworks, and checklists for K-12 schools.">
  <section class="py-12">
    <div class="container-wide">
      <h1 class="font-display text-4xl font-bold text-gray-900">AI Policies for Schools</h1>
      <p class="mt-3 text-lg text-gray-600 max-w-2xl">Board-ready templates, compliance frameworks, and implementation guides for responsible AI adoption.</p>
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map(p => (
          <a href={`/policy/${p.slug}/`} class="card group">
            <div class="flex items-center gap-2 mb-3">
              <span class="badge-blue capitalize">{p.data.type}</span>
              {p.data.downloadable && <span class="badge-green">Downloadable</span>}
              {p.data.gated && <span class="badge-yellow">Email Required</span>}
            </div>
            <h3 class="font-display font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">{p.data.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{p.data.description}</p>
            <div class="mt-3 flex flex-wrap gap-1">
              {p.data.audience.map(a => <span class="text-xs text-gray-500">{a}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
