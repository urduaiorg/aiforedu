---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema } from '../lib/schema';

export const prerender = true;

const policies = (await getCollection('policies'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const guides = (await getCollection('guides'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const featuredResources = [
  {
    label: 'Free starter',
    title: 'AI acceptable-use policy starter',
    description: 'A gated starter resource for teams that need a clean place to begin their policy work.',
    href: '/downloads/ai-policy-template/',
  },
  {
    label: 'Checklist',
    title: 'FERPA compliance checklist',
    description: 'A practical checklist for evaluating whether an AI tool is ready for school or district review.',
    href: '/policy/ferpa-ai-compliance-checklist/',
  },
  {
    label: 'Framework',
    title: 'Parent communication checklist',
    description: 'A free communication framework for explaining AI use to families clearly and responsibly.',
    href: '/policy/parent-communication-checklist-for-school-ai/',
  },
];

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', url: 'https://aiforedu.ai/' },
    { name: 'Resources', url: 'https://aiforedu.ai/resources/' },
  ]),
];
---

<BaseLayout
  title="Free AI Resources"
  description="Free AI policy templates, implementation guides, and practical education resources for educators and institutions worldwide."
  ogType="article"
  structuredData={structuredData}
>
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <div class="max-w-3xl">
        <p class="eyebrow">Resources</p>
        <h1 class="mt-6 page-title">Free AI resources for educators and institutions.</h1>
        <p class="page-lede">Use this hub to find the site's starter templates, policy frameworks, and practical implementation guidance without digging through the full library.</p>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid gap-5 md:grid-cols-3">
        {featuredResources.map((item) => (
          <a href={item.href} class="group index-card">
            <span class="badge-blue">{item.label}</span>
            <h2 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-ink-500">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-paper-300/90 bg-paper-100/50">
    <div class="container-full">
      <div class="mb-8 max-w-2xl">
        <p class="section-label">Policies and frameworks</p>
        <h2 class="mt-3 font-display text-display-sm text-ink-950">Free governance resources.</h2>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {policies.map((policy) => (
          <a href={`/policy/${policy.slug}/`} class="group index-card">
            <div class="flex flex-wrap items-center gap-2">
              <span class="badge-blue capitalize">{policy.data.type}</span>
              {policy.data.downloadable && <span class="badge-green">Downloadable</span>}
              {policy.data.gated && <span class="badge-yellow">Email required</span>}
            </div>
            <h3 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{policy.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink-500">{policy.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="mb-8 max-w-2xl">
        <p class="section-label">Guides</p>
        <h2 class="mt-3 font-display text-display-sm text-ink-950">Implementation guidance worth starting with.</h2>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
        {guides.map((guide) => (
          <a href={`/guides/${guide.slug}/`} class="group index-card">
            <span class="badge-blue">{guide.data.category}</span>
            <h3 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{guide.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink-500">{guide.data.description}</p>
          </a>
        ))}
      </div>

      <div class="mt-10">
        <NewsletterSignup
          variant="hero"
          heading="Subscribe for every new resource"
          subheading="The newsletter is the main CTA while the library expands. Get free resources, new reviews, and practical AI-in-education guidance every Tuesday."
        />
      </div>
    </div>
  </section>
</BaseLayout>
