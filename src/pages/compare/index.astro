---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('comparisons');
const sorted = comparisons.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Tool Comparisons" description="Side-by-side comparisons of AI tools for education. Find the right fit for your school.">
  <section class="py-12">
    <div class="container-wide">
      <h1 class="font-display text-4xl font-bold text-gray-900">AI Tool Comparisons</h1>
      <p class="mt-3 text-lg text-gray-600 max-w-2xl">Side-by-side breakdowns to help you choose the right AI tool for your specific needs.</p>
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        {sorted.map(comp => (
          <a href={`/compare/${comp.slug}/`} class="card group">
            <span class="badge-blue mb-3">{comp.data.category}</span>
            <h3 class="font-display font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">{comp.data.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{comp.data.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {comp.data.tools.map(t => (
                <span class="text-xs bg-gray-100 px-2 py-1 rounded-full text-gray-700">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
