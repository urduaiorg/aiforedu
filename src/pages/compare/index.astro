---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const comparisons = await getCollection('comparisons');
const sorted = comparisons.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="AI Tool Comparisons" description="Side-by-side comparisons of AI tools for education. Find the right fit for your school.">
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <p class="eyebrow">Decision support</p>
      <h1 class="mt-6 page-title">AI tool comparisons for high-stakes choices.</h1>
      <p class="page-lede">Use side-by-side breakdowns to compare platforms before demos, pilots, or procurement conversations begin.</p>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {sorted.map(comp => (
          <a href={`/compare/${comp.slug}/`} class="group index-card">
            <span class="badge-blue">{comp.data.category}</span>
            <h3 class="mt-4 font-display text-display-xs text-ink-950 group-hover:text-brand-700">{comp.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink-500">{comp.data.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {comp.data.tools.map(t => (
                <span class="metric-chip">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
