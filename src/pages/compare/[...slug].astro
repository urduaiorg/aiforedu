---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema, itemListSchema, articleSchema } from '../../lib/schema';
import { getAuthor } from '../../data/authors';

export const prerender = true;

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map(c => ({ params: { slug: c.slug }, props: { comparison: c } }));
}

const { comparison } = Astro.props;
const { Content } = await comparison.render();
const author = getAuthor('editorial-desk');

const compUrl = `https://aiforedu.ai/compare/${comparison.slug}/`;

// Build ItemList entries from the tools array
const allTools = await getCollection('tools');
const matchedTools = comparison.data.tools
  .map(name => allTools.find(t => t.data.title === name))
  .filter(Boolean);

// Related content
const allGuides = await getCollection('guides');
const relatedGuides = allGuides.slice(0, 2);

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', url: 'https://aiforedu.ai/' },
    { name: 'Comparisons', url: 'https://aiforedu.ai/compare/' },
    { name: comparison.data.title, url: compUrl },
  ]),
  articleSchema({
    headline: comparison.data.title,
    description: comparison.data.description,
    datePublished: comparison.data.publishDate.toISOString(),
    dateModified: comparison.data.lastUpdated.toISOString(),
    url: compUrl,
    authorName: author.name,
  }),
  itemListSchema({
    name: comparison.data.title,
    description: comparison.data.description,
    items: matchedTools.map((tool, i) => ({
      name: tool!.data.title,
      url: `https://aiforedu.ai/tools/${tool!.slug}/`,
      position: i + 1,
    })),
  }),
];
---

<BaseLayout
  title={comparison.data.title}
  description={comparison.data.description}
  ogType="article"
  structuredData={structuredData}
  publishDate={comparison.data.publishDate}
  modifiedDate={comparison.data.lastUpdated}
>
  <article class="section-shell-tight">
    <div class="container-full">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span class="divider-dot"></span>
        <a href="/compare/">Comparisons</a>
        <span class="divider-dot"></span>
        <span>{comparison.data.title}</span>
      </nav>

      <div class="mt-6 article-frame">
        <div class="article-grid">
          <div>
            <p class="section-label">Comparison report</p>
            <h1 class="mt-3 page-title">{comparison.data.title}</h1>
            <p class="page-lede">{comparison.data.description}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {comparison.data.tools.map(t => <span class="badge-blue">{t}</span>)}
            </div>
            <div class="mt-4 flex items-center gap-3 text-sm text-ink-500">
              <span>By <strong class="text-ink-700">{author.name}</strong>, {author.role}</span>
              <span class="divider-dot"></span>
              <span>{comparison.data.lastUpdated.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </div>
            <div class="prose-content mt-12"><Content /></div>
          </div>

          <aside class="article-rail">
            <div class="article-rail-card">
              <p class="label">About the author</p>
              <p class="mt-2 text-sm font-semibold text-ink-900">{author.name}</p>
              <p class="mt-1 text-xs text-ink-500">{author.role} · {author.credential}</p>
            </div>
            {matchedTools.length > 0 && (
              <div class="article-rail-card">
                <p class="label">Featured tools</p>
                <div class="mt-3 space-y-2">
                  {matchedTools.map(tool => (
                    <a href={`/tools/${tool!.slug}/`} class="block text-sm font-medium text-ink-700 hover:text-brand-700">
                      {tool!.data.title} — {tool!.data.rating}/5
                    </a>
                  ))}
                </div>
              </div>
            )}
            {relatedGuides.length > 0 && (
              <div class="article-rail-card">
                <p class="label">Related guides</p>
                <div class="mt-3 space-y-2">
                  {relatedGuides.map(g => (
                    <a href={`/guides/${g.slug}/`} class="block text-sm font-medium text-ink-700 hover:text-brand-700">{g.data.title}</a>
                  ))}
                </div>
              </div>
            )}
            <div class="article-rail-card">
              <p class="label">Methodology</p>
              <p class="mt-3 text-sm leading-7 text-ink-500">Read how AIForEdu evaluates and compares AI tools for education.</p>
              <a href="/methodology/" class="btn-secondary mt-5 w-full justify-center">Review the method</a>
            </div>
          </aside>
        </div>
      </div>

      <div class="mt-10">
        <NewsletterSignup variant="banner" heading="Get comparisons like this every week" subheading="Join educators tracking AI tools with one concise Tuesday briefing." />
      </div>
    </div>
  </article>
</BaseLayout>
