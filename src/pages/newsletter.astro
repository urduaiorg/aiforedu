---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout title="Free Newsletter" description="Weekly AI-in-education briefing for school leaders. One tool review, one policy tip, one action step — every Tuesday.">
  <section class="py-16">
    <div class="container-narrow text-center">
      <span class="badge-green text-sm">Free · Every Tuesday</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl font-bold text-gray-900">The AI-in-Ed Weekly</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-xl mx-auto">One tool review, one policy tip, one action step — everything a school leader needs to stay ahead of AI, delivered in under 5 minutes.</p>

      <div class="mt-10">
        <NewsletterSignup variant="hero" heading="Join 2,500+ School Leaders" subheading="Get your free AI Policy Template when you subscribe." />
      </div>

      <div class="mt-16 text-left max-w-xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-gray-900">What you'll get every week:</h2>
        <div class="mt-6 space-y-4">
          <div class="flex gap-4">
            <span class="text-2xl">🔍</span>
            <div><p class="font-semibold text-gray-900">Tool of the Week</p><p class="text-sm text-gray-600">In-depth review with compliance check, pricing breakdown, and classroom fit rating.</p></div>
          </div>
          <div class="flex gap-4">
            <span class="text-2xl">📋</span>
            <div><p class="font-semibold text-gray-900">Policy Spotlight</p><p class="text-sm text-gray-600">One actionable policy tip or template update you can use immediately.</p></div>
          </div>
          <div class="flex gap-4">
            <span class="text-2xl">⚡</span>
            <div><p class="font-semibold text-gray-900">Action Step</p><p class="text-sm text-gray-600">One concrete thing you can do this week to advance your AI strategy.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
