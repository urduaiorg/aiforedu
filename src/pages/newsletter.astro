---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout title="Free Newsletter" description="Weekly AI-in-education briefing for school leaders. One tool review, one policy tip, one action step — every Tuesday.">
  <section class="page-hero section-shell">
    <div class="container-full">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-end">
        <div class="max-w-3xl">
          <p class="eyebrow">Newsletter</p>
          <h1 class="mt-6 page-title">The AI-in-Ed Weekly.</h1>
          <p class="page-lede">One tool review, one policy signal, and one action step for school leaders who want to stay ahead of AI without spending hours sorting noise.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Cadence</p>
          <p class="mt-3 font-display text-display-xs text-ink-950">Every Tuesday</p>
          <p class="mt-2 text-sm leading-7 text-ink-500">Short enough to read quickly, substantial enough to inform a real decision.</p>
        </div>
      </div>

      <div class="mt-10">
        <NewsletterSignup variant="hero" heading="Get the weekly briefing" subheading="Subscribe for a concise weekly note and access to the free AI policy starter." />
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-narrow">
      <div class="space-y-4">
        <div class="editorial-panel">
          <p class="label">01</p>
          <h2 class="mt-3 font-display text-display-xs text-ink-950">Tool of the week</h2>
          <p class="mt-3 text-sm leading-7 text-ink-500">A focused review with compliance context, pricing implications, and practical fit for school environments.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">02</p>
          <h2 class="mt-3 font-display text-display-xs text-ink-950">Policy spotlight</h2>
          <p class="mt-3 text-sm leading-7 text-ink-500">A governance or implementation issue worth addressing now, translated into plain leadership language.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">03</p>
          <h2 class="mt-3 font-display text-display-xs text-ink-950">Action step</h2>
          <p class="mt-3 text-sm leading-7 text-ink-500">One concrete move your team can make this week to advance AI readiness responsibly.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
