---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const latestTools = allTools.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 6);
const displayTools = featuredTools.length > 0 ? featuredTools : latestTools;

const categories = [
  { name: 'Writing & Feedback', slug: 'writing', desc: 'Student writing support and teacher feedback', icon: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10', color: 'from-blue-500/10 to-indigo-500/10', iconColor: 'text-blue-600' },
  { name: 'Grading & Assessment', slug: 'grading', desc: 'Automated grading and rubric builders', icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25', color: 'from-violet-500/10 to-purple-500/10', iconColor: 'text-violet-600' },
  { name: 'Lesson Planning', slug: 'lesson-planning', desc: 'AI-powered curriculum helpers', icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25', color: 'from-emerald-500/10 to-green-500/10', iconColor: 'text-emerald-600' },
  { name: 'Admin & Ops', slug: 'admin', desc: 'Management, scheduling, comms', icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z', color: 'from-amber-500/10 to-orange-500/10', iconColor: 'text-amber-600' },
  { name: 'Student-Facing', slug: 'student-facing', desc: 'Tutoring, study aids, productivity', icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z', color: 'from-rose-500/10 to-pink-500/10', iconColor: 'text-rose-600' },
  { name: 'Special Education', slug: 'special-ed', desc: 'IEP tools and accessibility', icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z', color: 'from-teal-500/10 to-cyan-500/10', iconColor: 'text-teal-600' },
];
---

<BaseLayout title="Home">

  <!-- ==================== HERO — EDITORIAL, LIGHT, ASYMMETRIC ==================== -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50/60 via-white to-accent-50/40"></div>
    <!-- Floating decorative shapes -->
    <div class="absolute top-20 right-[10%] w-72 h-72 bg-primary-200/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-10 left-[5%] w-56 h-56 bg-accent-200/20 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
    <div class="absolute top-1/2 right-[30%] w-40 h-40 bg-warm-200/15 rounded-full blur-2xl animate-float" style="animation-delay: -1.5s;"></div>

    <div class="relative container-wide pt-16 pb-20 md:pt-24 md:pb-32 lg:pt-32 lg:pb-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
        <!-- Left: Text — takes 7 cols -->
        <div class="lg:col-span-7" data-animate>
          <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-white border border-gray-200/80 shadow-sm text-sm text-gray-600 mb-8">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-accent-500"></span>
              <span class="font-medium text-gray-900">500+ school leaders</span>
            </span>
            <span class="text-gray-300">|</span>
            <span>50+ tools reviewed</span>
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-gray-900 leading-[1.05]">
            The AI library<br />
            for <span class="hand-underline">school leaders</span>
          </h1>

          <p class="mt-7 text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed">
            Unbiased tool reviews, ready&#8209;to&#8209;adopt policies, and step&#8209;by&#8209;step guides. Everything you need to bring AI into your school — confidently.
          </p>

          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/tools/" class="btn-primary text-base group">
              Browse Tools
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="#free-template" class="btn-secondary text-base">Get Free Policy Template</a>
          </div>
        </div>

        <!-- Right: Visual element — bento preview grid — takes 5 cols -->
        <div class="lg:col-span-5 hidden lg:block" data-animate="scale">
          <div class="grid grid-cols-2 gap-3">
            <!-- Card 1: Large -->
            <div class="col-span-2 gradient-border p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-primary-100 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-900">AI Tool Reviews</p>
                  <p class="text-xs text-gray-400">Independent & unbiased</p>
                </div>
              </div>
              <div class="flex gap-1.5">
                <span class="badge-green text-[10px]">FERPA</span>
                <span class="badge-blue text-[10px]">Free</span>
                <span class="badge-yellow text-[10px]">K-12</span>
              </div>
            </div>
            <!-- Card 2 -->
            <div class="bg-gray-900 rounded-2xl p-4 text-white">
              <svg class="w-6 h-6 text-primary-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <p class="text-sm font-semibold">Policy Templates</p>
              <p class="text-xs text-gray-400 mt-0.5">Board-ready</p>
            </div>
            <!-- Card 3 -->
            <div class="bg-accent-50 rounded-2xl p-4">
              <svg class="w-6 h-6 text-accent-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
              <p class="text-sm font-semibold text-gray-900">Comparisons</p>
              <p class="text-xs text-gray-500 mt-0.5">Side by side</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SCROLLING SOCIAL PROOF MARQUEE ==================== -->
  <section class="border-y border-gray-100 bg-white py-4 overflow-hidden">
    <div class="marquee-track">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-12 px-6 shrink-0">
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">50+ Tools Reviewed</span>
          </span>
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">Every Tool FERPA-Checked</span>
          </span>
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">Independent Ratings</span>
          </span>
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">Updated Monthly</span>
          </span>
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">U.S. K-12 Focused</span>
          </span>
          <span class="flex items-center gap-2 text-sm text-gray-400 whitespace-nowrap">
            <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span class="font-medium text-gray-600">2,500+ Subscribers</span>
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ==================== CATEGORIES — BENTO GRID ==================== -->
  <section class="section">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12" data-animate>
        <div>
          <span class="section-label">Categories</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">Browse by what you need</h2>
        </div>
        <a href="/tools/" class="text-sm font-medium text-primary-600 hover:text-primary-700 flex items-center gap-1 transition-colors shrink-0">
          View all tools
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>

      <!-- Bento grid: 2 tall on left, 4 small on right -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
        {categories.map((cat, i) => (
          <a
            href={`/tools/?category=${cat.slug}`}
            class:list={[
              'group relative overflow-hidden rounded-2xl border border-gray-100 bg-white p-6 hover:border-gray-200 hover:shadow-card-hover transition-all duration-300',
              i === 0 && 'lg:row-span-2 lg:flex lg:flex-col lg:justify-between lg:p-8',
            ]}
          >
            <div class:list={[
              'absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br',
              cat.color,
            ]}></div>
            <div class="relative">
              <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-colors', i === 0 ? 'bg-primary-50 group-hover:bg-primary-100' : 'bg-gray-50 group-hover:bg-gray-100']}>
                <svg class:list={['w-6 h-6', cat.iconColor]} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
                </svg>
              </div>
              <h3 class:list={['font-bold text-gray-900 group-hover:text-gray-900', i === 0 ? 'text-xl' : 'text-base']}>{cat.name}</h3>
              <p class:list={['text-gray-500 mt-1.5', i === 0 ? 'text-sm' : 'text-xs']}>{cat.desc}</p>
            </div>
            <div class:list={['flex items-center gap-1 text-xs font-medium text-primary-600 opacity-0 group-hover:opacity-100 transition-opacity', i === 0 ? 'mt-auto pt-6' : 'mt-4']}>
              Explore
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED TOOLS ==================== -->
  {displayTools.length > 0 && (
    <section class="section-sm bg-surface-50 border-y border-gray-100">
      <div class="container-wide">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10" data-animate>
          <div>
            <span class="section-label">Reviews</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">Top-rated tools</h2>
            <p class="mt-2 text-gray-500 text-sm max-w-lg">Every tool tested by real educators. Rated on ease of use, pedagogical value, data privacy, and price.</p>
          </div>
          <a href="/tools/" class="text-sm font-medium text-primary-600 hover:text-primary-700 flex items-center gap-1 transition-colors shrink-0">
            View all
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-stagger>
          {displayTools.map(tool => (
            <ToolCard
              title={tool.data.title}
              slug={tool.slug}
              description={tool.data.description}
              category={tool.data.category}
              pricing={tool.data.pricing}
              rating={tool.data.rating}
              ferpaCompliant={tool.data.ferpaCompliant}
              bestFor={tool.data.bestFor}
              featured={tool.data.featured}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ==================== HOW IT WORKS — ASYMMETRIC SPLIT ==================== -->
  <section class="section">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <!-- Left: Heading — editorial style, left-aligned -->
        <div data-animate="left">
          <span class="section-label">How It Works</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-[1.1]">
            From research<br />to <span class="gradient-text">responsible rollout</span>
          </h2>
          <p class="mt-6 text-gray-500 text-lg leading-relaxed max-w-md">
            A practical, proven path that takes you from exploring tools to board approval to classroom implementation.
          </p>
          <a href="/guides/" class="mt-8 btn-primary inline-flex group">
            Read the Guides
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <!-- Right: Steps — stacked cards -->
        <div class="space-y-4" data-stagger>
          <div class="flex gap-5 items-start p-5 rounded-2xl bg-surface-50 border border-gray-100 hover:bg-white hover:shadow-card hover:border-gray-200 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-primary-600 text-white flex items-center justify-center shrink-0 font-bold text-lg">1</div>
            <div>
              <h3 class="font-bold text-gray-900">Browse & Compare</h3>
              <p class="mt-1 text-sm text-gray-500 leading-relaxed">Search 50+ independently reviewed AI tools. Filter by grade level, subject, compliance status, and price.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start p-5 rounded-2xl bg-surface-50 border border-gray-100 hover:bg-white hover:shadow-card hover:border-gray-200 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-primary-600 text-white flex items-center justify-center shrink-0 font-bold text-lg">2</div>
            <div>
              <h3 class="font-bold text-gray-900">Get the Policies</h3>
              <p class="mt-1 text-sm text-gray-500 leading-relaxed">Download free templates or grab the full Policy Kit. Present to your board with confidence.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start p-5 rounded-2xl bg-surface-50 border border-gray-100 hover:bg-white hover:shadow-card hover:border-gray-200 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-primary-600 text-white flex items-center justify-center shrink-0 font-bold text-lg">3</div>
            <div>
              <h3 class="font-bold text-gray-900">Implement with Guides</h3>
              <p class="mt-1 text-sm text-gray-500 leading-relaxed">Follow step-by-step guides and the Readiness Workbook to roll out AI responsibly across your district.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FREE TEMPLATE CTA ==================== -->
  <section id="free-template" class="section-sm">
    <div class="container-wide">
      <div class="gradient-border p-8 md:p-14" data-animate="scale">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <!-- Left: Content -->
          <div>
            <span class="badge-green mb-4">Free Download</span>
            <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 leading-tight">AI Acceptable-Use<br />Policy Template</h2>
            <p class="mt-4 text-gray-500 text-sm leading-relaxed">Board-ready, 12-section policy template covering FERPA, COPPA, academic integrity, and more. Used by 200+ districts nationwide.</p>
            <ul class="mt-5 space-y-2">
              {['FERPA & COPPA compliant', 'Board presentation ready', 'Editable Google Docs format'].map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-accent-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: Form -->
          <div
            x-data="{ email: '', done: false }"
            class="bg-surface-50 rounded-2xl p-6 md:p-8 border border-gray-100"
          >
            <template x-if="!done">
              <form
                class="space-y-4"
                @submit.prevent="
                  const res = await fetch('/api/free-download', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, resource: 'ai-policy-template' })
                  });
                  if (res.ok) done = true;
