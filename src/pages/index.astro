---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const latestTools = allTools.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 6);
const displayTools = featuredTools.length > 0 ? featuredTools : latestTools;

const categories = [
  { name: 'Writing & Feedback', slug: 'writing', desc: 'AI tools for student writing support and teacher feedback', icon: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10' },
  { name: 'Grading & Assessment', slug: 'grading', desc: 'Automated grading, rubric builders, and assessment tools', icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25' },
  { name: 'Lesson Planning', slug: 'lesson-planning', desc: 'AI-powered lesson generators and curriculum helpers', icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25' },
  { name: 'Admin & Operations', slug: 'admin', desc: 'School management, scheduling, and communications', icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z' },
  { name: 'Student-Facing', slug: 'student-facing', desc: 'Tutoring bots, study aids, and student productivity', icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z' },
  { name: 'Special Education', slug: 'special-ed', desc: 'IEP tools, accommodations, and accessibility helpers', icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z' },
];

const stats = [
  { value: '50+', label: 'Tools Reviewed' },
  { value: '100%', label: 'FERPA-Checked' },
  { value: '2,500+', label: 'School Leaders' },
  { value: 'Monthly', label: 'Updates' },
];

const steps = [
  {
    number: '01',
    title: 'Browse & Compare',
    description: 'Search 50+ independently reviewed AI tools filtered by grade level, subject, compliance, and price.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
  },
  {
    number: '02',
    title: 'Get the Policies',
    description: 'Download free templates or grab the full Policy Kit to present to your board with confidence.',
    icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25',
  },
  {
    number: '03',
    title: 'Implement with Guides',
    description: 'Follow step-by-step guides and the Readiness Workbook to roll out AI responsibly.',
    icon: 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  },
];
---

<BaseLayout title="Home">

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-gray-950 via-primary-950 to-gray-900 text-white">
    <!-- Ambient glow -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-500/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/5 rounded-full blur-3xl"></div>
    </div>

    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="relative container-wide py-24 md:py-32 lg:py-40">
      <div class="max-w-3xl" data-animate>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-sm text-primary-200 mb-6">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          Trusted by 500+ school leaders nationwide
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.1] tracking-tight">
          The AI Library<br />
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary-300 via-primary-200 to-accent-300">Built for School Leaders</span>
        </h1>

        <p class="mt-6 text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
          Unbiased tool reviews, ready-to-adopt policies, and step-by-step guides — everything you need to bring AI into your school confidently and responsibly.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/tools/" class="btn-primary !bg-white !text-gray-900 hover:!bg-gray-100 text-base shadow-elevated">
            Browse Tool Reviews
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="#free-template" class="btn-secondary !border-white/20 !text-white hover:!bg-white/10 !backdrop-blur-sm text-base">
            Get Free Policy Template
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== STATS BAR ==================== -->
  <section class="relative -mt-8 z-10">
    <div class="container-wide">
      <div class="bg-white rounded-2xl shadow-elevated border border-gray-100 p-6 md:p-0" data-animate>
        <div class="grid grid-cols-2 md:grid-cols-4 md:divide-x divide-gray-100">
          {stats.map(stat => (
            <div class="flex flex-col items-center py-4 md:py-6">
              <span class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">{stat.value}</span>
              <span class="mt-1 text-xs md:text-sm text-gray-500 font-medium">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CATEGORIES ==================== -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto" data-animate>
        <span class="section-overline">Categories</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Browse by Category</h2>
        <p class="mt-4 text-gray-500 leading-relaxed">Every tool independently reviewed for privacy compliance, pedagogical value, and practical classroom fit.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-animate>
        {categories.map(cat => (
          <a href={`/tools/?category=${cat.slug}`} class="group relative flex items-start gap-4 p-5 rounded-2xl border border-gray-100 bg-white hover:border-primary-200 hover:shadow-card transition-all duration-300 ease-out">
            <div class="w-11 h-11 rounded-xl bg-primary-50 flex items-center justify-center shrink-0 group-hover:bg-primary-100 transition-colors">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">{cat.name}</h3>
              <p class="mt-1 text-sm text-gray-500 leading-relaxed">{cat.desc}</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 group-hover:text-primary-400 absolute top-5 right-5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED TOOLS ==================== -->
  {displayTools.length > 0 && (
    <section class="section-sm bg-surface-50">
      <div class="container-wide">
        <div class="flex items-end justify-between gap-4" data-animate>
          <div>
            <span class="section-overline">Reviews</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Top-Rated Tools</h2>
          </div>
          <a href="/tools/" class="hidden sm:inline-flex items-center gap-1.5 text-primary-600 font-medium text-sm hover:text-primary-700 transition-colors shrink-0">
            View all tools
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-animate>
          {displayTools.map(tool => (
            <ToolCard
              title={tool.data.title}
              slug={tool.slug}
              description={tool.data.description}
              category={tool.data.category}
              pricing={tool.data.pricing}
              rating={tool.data.rating}
              ferpaCompliant={tool.data.ferpaCompliant}
              bestFor={tool.data.bestFor}
              featured={tool.data.featured}
            />
          ))}
        </div>
        <div class="mt-8 text-center sm:hidden">
          <a href="/tools/" class="btn-secondary text-sm">View All Tools</a>
        </div>
      </div>
    </section>
  )}

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto" data-animate>
        <span class="section-overline">How It Works</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Three Steps to AI-Ready Schools</h2>
        <p class="mt-4 text-gray-500 leading-relaxed">A practical, proven path from research to responsible implementation.</p>
      </div>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12" data-animate>
        {steps.map((step, i) => (
          <div class="relative text-center group">
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-12 left-[60%] w-[80%] border-t-2 border-dashed border-gray-200"></div>
            )}
            <div class="relative z-10 w-16 h-16 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto group-hover:bg-primary-100 transition-colors">
              <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
              </svg>
            </div>
            <span class="inline-block mt-4 text-xs font-bold text-primary-600 bg-primary-50 px-2.5 py-0.5 rounded-full">{step.number}</span>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{step.title}</h3>
            <p class="mt-2 text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FREE TEMPLATE CTA ==================== -->
  <section id="free-template" class="section-sm bg-surface-50">
    <div class="container-wide">
      <div class="relative overflow-hidden bg-gradient-to-br from-accent-600 to-accent-700 rounded-3xl p-8 md:p-14 text-white" data-animate>
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent-800/30 rounded-full translate-y-1/2 -translate-x-1/4 blur-2xl"></div>

        <div class="relative max-w-2xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/15 text-sm font-medium text-white/90 mb-5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
            Free Download
          </div>

          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">Free AI Acceptable-Use Policy Template</h2>
          <p class="mt-4 text-accent-100 text-sm md:text-base leading-relaxed max-w-lg mx-auto">Board-ready, 12-section policy template covering FERPA, COPPA, academic integrity, and more. Used by 200+ districts nationwide.</p>

          <form
            class="mt-8 max-w-md mx-auto flex flex-col sm:flex-row gap-3"
            x-data="{ email: '', done: false }"
            @submit.prevent="
              const res = await fetch('/api/free-download', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, resource: 'ai-policy-template' })
              });
              if (res.ok) done = true;
            "
          >
            <template x-if="!done">
              <div class="flex flex-col sm:flex-row gap-3 w-full">
                <input type="email" x-model="email" placeholder="you@school.edu" required class="flex-1 px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm focus:outline-none focus:ring-2 focus:ring-white/40" />
                <button type="submit" class="px-6 py-3 rounded-xl bg-white text-accent-700 font-medium text-sm hover:bg-accent-50 transition-all duration-200 whitespace-nowrap shadow-sm hover:-translate-y-0.5 active:translate-y-0">Download Free</button>
              </div>
            </template>
            <template x-if="done">
              <p class="text-white font-semibold py-3 flex items-center gap-2 justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Check your inbox — the template is on its way!
              </p>
            </template>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PRODUCTS ==================== -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto" data-animate>
        <span class="section-overline">Premium Resources</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Save Weeks of Work</h2>
        <p class="mt-4 text-gray-500 leading-relaxed">Ready-to-implement toolkits for districts serious about AI adoption. Vetted by education consultants.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start" data-animate>
        <ProductCard
          title="AI Policy Kit"
          price="$29"
          badge="Best Seller"
          popular={true}
          description="Complete policy bundle for district-wide AI adoption."
          features={['5 editable policy templates', 'Board presentation deck', 'Parent communication guide', 'Staff training checklist', 'FERPA compliance matrix']}
          href="/products/policy-kit/"
        />
        <ProductCard
          title="Readiness Workbook"
          price="$19"
          description="Self-assessment and planning tool for AI integration."
          features={['Infrastructure audit checklist', '90-day implementation plan', 'Budget planning worksheet', 'Stakeholder survey templates', 'Progress tracking dashboard']}
          href="/products/readiness-workbook/"
        />
        <ProductCard
          title="Tool Vetting Pack"
          price="$39"
          badge="Most Comprehensive"
          description="Everything you need to evaluate and approve AI tools."
          features={['Vendor evaluation rubric', 'Security questionnaire template', 'Pilot program framework', '50+ pre-vetted tool profiles', 'Comparison spreadsheet']}
          href="/products/tool-vetting-pack/"
        />
      </div>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section class="section-sm bg-surface-50">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto" data-animate>
        <span class="section-overline">What Leaders Say</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Trusted by School Leaders</h2>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6" data-animate>
        <div class="bg-white rounded-2xl border border-gray-100 p-7 shadow-card">
          <div class="flex items-center gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">"AIForEdu saved our team months of research. The policy templates alone were worth every penny — our board approved them in one meeting."</p>
          <div class="mt-5 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center">
              <span class="text-sm font-bold text-primary-600">SK</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">Dr. Sarah Kim</p>
              <p class="text-xs text-gray-500">Superintendent, Westfield USD</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-7 shadow-card">
          <div class="flex items-center gap-0.5 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">"The tool comparison pages are exactly what I needed. Unbiased, thorough, and actually focused on K-12 — not generic enterprise reviews."</p>
          <div class="mt-5 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-accent-100 flex items-center justify-center">
              <span class="text-sm font-bold text-accent-600">MJ</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">Marcus Johnson</p>
              <p class="text-xs text-gray-500">Technology Director, Lincoln PS</p>
            </div>
          </div>
        </div>

