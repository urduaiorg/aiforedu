                </button>
                <p class="text-xs text-gray-400 text-center">No spam. Instant download link to your inbox.</p>
              </form>
            </template>
            <template x-if="done">
              <div class="text-center py-6">
                <div class="w-12 h-12 rounded-full bg-accent-100 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                </div>
                <p class="font-bold text-gray-900">Check your inbox!</p>
                <p class="text-sm text-gray-500 mt-1">The template is on its way.</p>
