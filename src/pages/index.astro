---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import { toolCategoryMeta, toolCategoryOrder } from '../data/toolCategories';
import { editorialSignals, readerQuestions } from '../data/editorial';

export const prerender = true;

const allTools = await getCollection('tools');
const allPolicies = await getCollection('policies');
const allGuides = await getCollection('guides');
const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const latestTools = allTools.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 6);
const displayTools = featuredTools.length > 0 ? featuredTools : latestTools;
const avgRating = (allTools.reduce((sum, tool) => sum + tool.data.rating, 0) / allTools.length).toFixed(1);
const categoriesByCount = allTools.reduce((acc, tool) => {
  acc[tool.data.category] = (acc[tool.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categories = toolCategoryOrder
  .filter((slug) => categoriesByCount[slug])
  .map((slug) => ({
    slug,
    name: toolCategoryMeta[slug].label,
    description: toolCategoryMeta[slug].description,
    count: categoriesByCount[slug],
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);
---

<BaseLayout title="Home">
  <section class="page-hero section-shell">
    <div class="container-full">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_24rem] lg:items-end">
        <div data-reveal>
          <p class="eyebrow">For superintendents, principals, and district teams</p>
          <h1 class="mt-6 max-w-4xl font-display text-[3.4rem] leading-[0.95] text-ink-950 md:text-hero">
            The AI intelligence desk for modern school leadership.
          </h1>
          <p class="page-lede max-w-2xl">
            Independent tool reviews, implementation guidance, and board-ready policy resources designed to help schools adopt AI with more rigor, more speed, and fewer blind spots.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/tools/" class="btn-primary">Explore the library</a>
            <a href="#free-template" class="btn-secondary">Access the free policy starter</a>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="metric-chip">{allTools.length} reviewed tools</span>
            <span class="metric-chip">{allPolicies.length} policy assets</span>
            <span class="metric-chip">{allGuides.length} implementation guides</span>
            <span class="metric-chip">{avgRating}/5 average rating</span>
          </div>
        </div>

        <div class="editorial-panel-dark" data-reveal>
          <p class="section-label text-brand-200">Review framework</p>
          <h2 class="mt-3 font-display text-display-xs text-white">Every recommendation has to clear an institutional bar.</h2>
          <div class="mt-6 space-y-4">
            <div class="article-rail-card border border-white/10 bg-white/5">
              <p class="label text-brand-200">01</p>
              <p class="value text-white">Privacy and compliance fit, including FERPA and COPPA signals.</p>
            </div>
            <div class="article-rail-card border border-white/10 bg-white/5">
              <p class="label text-brand-200">02</p>
              <p class="value text-white">Classroom and administrative usefulness in real school workflows.</p>
            </div>
            <div class="article-rail-card border border-white/10 bg-white/5">
              <p class="label text-brand-200">03</p>
              <p class="value text-white">Implementation readiness, board communication, and procurement confidence.</p>
            </div>
          </div>
          <a href="/methodology/" class="btn-secondary mt-6">Review the methodology</a>
        </div>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-4" data-reveal-stagger>
        <div class="kpi-card">
          <p class="kpi-value">{allTools.length}</p>
          <p class="kpi-caption">Active tool reviews with ratings, pricing, and compliance context.</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-value">{avgRating}</p>
          <p class="kpi-caption">Average rating across the current tool library.</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-value">{allPolicies.length + allGuides.length}</p>
          <p class="kpi-caption">Policy and implementation resources to support rollout decisions.</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-value">Tues</p>
          <p class="kpi-caption">A concise weekly briefing for leaders who need signal, not noise.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_1.2fr]">
        <div class="editorial-panel" data-reveal>
          <p class="section-label">Institutional promise</p>
          <h2 class="mt-3 font-display text-display-xs text-ink-950">Built for decision-makers who need judgment, not hype.</h2>
          <p class="mt-4 max-w-xl text-base leading-8 text-ink-500">
            Most AI sites speak to teachers or vendors. AIForEdu is designed for the people accountable for policy, procurement, governance, and responsible implementation across an entire school or district.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-3" data-reveal-stagger>
          <div class="info-card">
            <p class="label">Policy</p>
            <p class="value">Board-ready templates and governance language that reduce ambiguity.</p>
          </div>
          <div class="info-card">
            <p class="label">Procurement</p>
            <p class="value">Side-by-side reviews to help teams evaluate fit, risk, and value.</p>
          </div>
          <div class="info-card">
            <p class="label">Implementation</p>
            <p class="value">Practical rollout guidance for school leaders turning pilots into policy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-full">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div data-reveal>
          <p class="section-label">Coverage map</p>
          <h2 class="mt-3 font-display text-display-sm text-ink-950">The library is organized around real school decisions.</h2>
          <p class="mt-4 max-w-lg text-base leading-8 text-ink-500">
            Categories are structured around leadership questions: what solves a workflow problem, what introduces policy or procurement risk, and what is mature enough for district use.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2" data-reveal-stagger>
          {categories.map((cat) => (
            <a href={`/tools/category/${cat.slug}/`} class="index-card">
              <p class="label">{String(cat.count).padStart(2, '0')} reviews</p>
              <h3 class="mt-4 font-display text-display-xs text-ink-950">{cat.name}</h3>
              <p class="mt-3 text-sm leading-7 text-ink-500">{cat.description}</p>
              <div class="mt-6 btn-quiet">Open category</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {displayTools.length > 0 && (
    <section class="section-shell border-y border-paper-300/90 bg-paper-100/50">
      <div class="container-full">
        <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between" data-reveal>
          <div>
            <p class="section-label">Editors' picks</p>
            <h2 class="mt-3 font-display text-display-sm text-ink-950">Featured reviews</h2>
            <p class="mt-4 max-w-2xl text-base leading-8 text-ink-500">
              Start with the tools school leaders are most likely to evaluate first: high-visibility platforms with direct implications for privacy, classroom fit, and district readiness.
            </p>
          </div>
          <a href="/tools/" class="btn-secondary">Browse all reviews</a>
        </div>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3" data-reveal-stagger>
          {displayTools.map(tool => (
            <ToolCard
              title={tool.data.title}
              slug={tool.slug}
              description={tool.data.description}
              category={tool.data.category}
              pricing={tool.data.pricing}
              rating={tool.data.rating}
              ferpaCompliant={tool.data.ferpaCompliant}
              bestFor={tool.data.bestFor}
              featured={tool.data.featured}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-shell">
    <div class="container-full">
      <div class="grid gap-6 lg:grid-cols-3" data-reveal-stagger>
        <div class="editorial-panel">
          <p class="label">Step 01</p>
          <h3 class="mt-4 font-display text-display-xs text-ink-950">Screen the market intelligently.</h3>
          <p class="mt-3 text-sm leading-7 text-ink-500">Use the review library to narrow choices before your team spends time on demos, pilots, and board questions.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Step 02</p>
          <h3 class="mt-4 font-display text-display-xs text-ink-950">Align governance and policy.</h3>
          <p class="mt-3 text-sm leading-7 text-ink-500">Move from exploration to institutional readiness with practical policy language and adoption frameworks.</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Step 03</p>
          <h3 class="mt-4 font-display text-display-xs text-ink-950">Implement with confidence.</h3>
          <p class="mt-3 text-sm leading-7 text-ink-500">Roll out AI in a way that is legible to leadership teams, staff, families, and governing boards.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="free-template" class="section-shell">
    <div class="container-full">
      <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="cta-panel-dark" data-reveal>
          <p class="section-label text-brand-200">Free flagship resource</p>
          <h2 class="mt-3 font-display text-display-sm text-white">AI acceptable-use policy template</h2>
          <p class="mt-4 max-w-xl text-base leading-8 text-ink-200">
            A board-ready starting point covering acceptable use, privacy, academic integrity, and implementation guardrails for school systems beginning serious AI adoption work.
          </p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="article-rail-card border border-white/10 bg-white/5">
              <p class="label text-brand-200">Included</p>
              <p class="value text-white">Editable language for district and school adaptation.</p>
            </div>
            <div class="article-rail-card border border-white/10 bg-white/5">
              <p class="label text-brand-200">Focus</p>
              <p class="value text-white">FERPA, COPPA, integrity, and governance alignment.</p>
            </div>
          </div>
        </div>

        <div
          x-data="{ email: '', role: '', districtSize: '', organization: '', downloadUrl: '', done: false, error: '', successTitle: 'Resource ready', successMessage: 'Open the resource now.' }"
          class="cta-panel"
          data-reveal
        >
          <template x-if="!done">
            <form
              class="space-y-5"
              @submit.prevent="
                error = '';
                const res = await fetch('/api/free-download', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email, role, districtSize, organization, useCase: 'homepage-policy-template', resource: 'ai-policy-template' })
                });
                if (res.ok) {
                  const d = await res.json();
                  downloadUrl = d.downloadUrl || '';
                  successTitle = d.successTitle || successTitle;
                  successMessage = d.successMessage || successMessage;
                  done = true;
                } else {
                  const d = await res.json();
                  error = d.error || 'Something went wrong';
                }
              "
            >
              <div>
                <p class="section-label">Download access</p>
                <h3 class="mt-3 font-display text-display-xs text-ink-950">Get instant access to the starter.</h3>
                <p class="mt-3 max-w-xl text-sm leading-7 text-ink-500">Enter your work email and a little context. We unlock the resource immediately, and if email delivery is configured we send the follow-up guidance there as well.</p>
              </div>
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label">Work email</label>
                  <input type="email" x-model="email" placeholder="you@school.edu" required class="input" />
                </div>
                <div>
                  <label class="field-label">Organization</label>
                  <input type="text" x-model="organization" placeholder="District or school" class="input" />
                </div>
              </div>
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="field-label">Role</label>
                  <select x-model="role" class="select">
                    <option value="">Select your role</option>
                    <option value="superintendent">Superintendent</option>
                    <option value="principal">Principal or school leader</option>
                    <option value="district-innovation">District innovation lead</option>
                    <option value="technology">Technology / IT leader</option>
                    <option value="curriculum">Curriculum / instruction lead</option>
                    <option value="teacher">Teacher</option>
                  </select>
                </div>
                <div>
                  <label class="field-label">District size</label>
                  <select x-model="districtSize" class="select">
                    <option value="">Select size</option>
                    <option value="single-school">Single school</option>
                    <option value="small-district">Small district</option>
                    <option value="mid-size-district">Mid-size district</option>
                    <option value="large-district">Large district</option>
                    <option value="state-or-network">State / network</option>
                  </select>
                </div>
              </div>
              <button type="submit" class="btn-primary w-full justify-center">
                Unlock the resource
              </button>
              <p x-show="error" x-text="error" class="text-sm text-red-600"></p>
              <p class="small-note">Intended for school and district use. We only ask for enough context to understand who the resource is helping. See <a href="/privacy/" class="underline underline-offset-4">privacy</a>.</p>
            </form>
          </template>
          <template x-if="done">
            <div class="py-6">
              <p class="section-label">Request received</p>
              <p class="mt-3 font-display text-display-xs text-ink-950" x-text="successTitle">Resource ready.</p>
              <p class="mt-2 text-sm leading-7 text-ink-500" x-text="successMessage">Open the resource now.</p>
              <template x-if="downloadUrl">
                <a :href="downloadUrl" class="btn-primary mt-5 inline-flex">Open resource</a>
              </template>
            </div>
          </template>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-paper-300/90 bg-paper-100/50">
    <div class="container-full">
      <div class="mb-10 max-w-2xl" data-reveal>
        <p class="section-label">Premium resources</p>
        <h2 class="mt-3 font-display text-display-sm text-ink-950">Operational shortcuts for teams who need to move faster.</h2>
        <p class="mt-4 text-base leading-8 text-ink-500">These toolkits package policy, implementation, and evaluation materials into ready-to-use working sets for district and school leadership teams.</p>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3" data-reveal-stagger>
        <ProductCard
          title="AI Policy Kit"
          price="$29"
          badge="Most adopted"
          popular={true}
          description="Complete policy bundle for district-wide AI adoption."
          features={['5 editable policy templates', 'Board presentation deck', 'Parent communication guide', 'Staff training checklist', 'FERPA compliance matrix']}
          href="/products/policy-kit/"
        />
        <ProductCard
          title="Readiness Workbook"
          price="$19"
          description="Self-assessment and planning tool for AI integration."
          features={['Infrastructure audit checklist', '90-day implementation plan', 'Budget planning worksheet', 'Stakeholder survey templates', 'Progress tracking dashboard']}
          href="/products/readiness-workbook/"
        />
        <ProductCard
          title="Tool Vetting Pack"
          price="$39"
          badge="Most comprehensive"
          description="Everything you need to evaluate and approve AI tools."
          features={['Vendor evaluation rubric', 'Security questionnaire', 'Pilot program framework', 'Tool profile tracker', 'Comparison spreadsheet']}
          href="/products/tool-vetting-pack/"
        />
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-narrow" data-reveal>
      <div class="article-frame text-left">
        <p class="section-label">What leadership teams ask</p>
        <h2 class="mt-3 font-display text-display-sm text-ink-950">The questions behind most AI decisions in schools are human, not technical.</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {readerQuestions.map((question) => (
            <div class="info-card">
              <h3 class="value">{question}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-narrow" data-reveal>
      <div class="cta-panel text-center">
        <p class="section-label">Why trust this library</p>
        <h2 class="mt-3 font-display text-display-xs text-ink-950">The site earns trust by showing its work.</h2>
        <div class="mt-6 grid gap-4 text-left md:grid-cols-2">
          {editorialSignals.map((signal) => (
            <div class="info-card">
              <p class="value">{signal}</p>
            </div>
          ))}
        </div>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href="/methodology/" class="btn-secondary">Read the methodology</a>
          <a href="/about/" class="btn-secondary">See how the editorial desk works</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-narrow" data-reveal>
      <div class="cta-panel text-center">
        <p class="section-label">Field signal</p>
        <blockquote class="mt-4 font-display text-[1.9rem] leading-tight text-ink-950 md:text-display-xs">
          The strongest version of this product is not just a content library. It is a decision-support system that helps leadership teams move from curiosity to policy, procurement, and rollout with more confidence.
        </blockquote>
        <div class="mt-6">
          <p class="font-semibold text-ink-900">AIForEdu editorial position</p>
          <p class="small-note mt-1">Authority should come from clear method, transparent limits, and useful artifacts.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-narrow" data-reveal>
      <NewsletterSignup variant="hero" heading="Get a sharper read on school AI each week" subheading="One concise briefing covering a tool, a policy signal, and one practical action for leadership teams." />
    </div>
  </section>
</BaseLayout>
