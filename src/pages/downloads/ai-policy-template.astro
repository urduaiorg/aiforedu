---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout
  title="AI Policy Template Access"
  description="Access the AI acceptable-use policy starter and review the companion policy guidance for educators and institutions."
>
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <div class="max-w-3xl">
        <p class="eyebrow">Resource access</p>
        <h1 class="mt-6 page-title">AI acceptable-use policy starter.</h1>
        <p class="page-lede">
          This access page gives you the public starter version now, with the implementation context educators and institutions usually need before adapting policy language locally.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <div class="article-frame">
          <p class="section-label">What to do next</p>
          <div class="grid gap-4 md:grid-cols-3">
            <div class="info-card">
              <p class="label">1. Review</p>
              <p class="value">Open the starter policy and assess which sections already match your governance posture.</p>
            </div>
            <div class="info-card">
              <p class="label">2. Adapt</p>
              <p class="value">Modify language with district counsel, data privacy leads, and academic leadership.</p>
            </div>
            <div class="info-card">
              <p class="label">3. Expand</p>
              <p class="value">Continue to the free resources hub if you need more frameworks, guides, and newsletter follow-up.</p>
            </div>
          </div>

          <div class="cta-panel mt-8">
            <p class="section-label">Starter version</p>
            <h2 class="mt-3 font-display text-display-xs text-ink-950">Read the public policy page.</h2>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-500">
              The public version covers the baseline structure and implementation guidance. It is the fastest way to review the framework before tailoring it to your own context.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href="/policy/ai-acceptable-use-policy/" class="btn-primary">Open the policy template</a>
              <a href="/resources/" class="btn-secondary">Browse more free resources</a>
            </div>
          </div>
        </div>

        <aside class="article-rail">
          <div class="article-rail-card">
            <p class="label">Includes</p>
            <p class="mt-3 text-sm leading-7 text-ink-500">Starter language for acceptable use, governance alignment, privacy considerations, and implementation framing.</p>
          </div>
          <div class="article-rail-card">
            <p class="label">Important note</p>
            <p class="mt-3 text-sm leading-7 text-ink-500">This is a planning resource, not legal advice. Final policy language should be reviewed by your district counsel and decision-makers.</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
