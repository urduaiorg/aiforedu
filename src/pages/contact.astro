---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Contact Us" description="Get in touch with the AIForEdu.ai team. Questions, partnerships, and listing inquiries welcome.">
  <section class="page-hero section-shell-tight">
    <div class="container-full">
      <div class="max-w-3xl">
        <p class="eyebrow">Contact</p>
        <h1 class="mt-6 page-title">Get in touch with the editorial and advisory team.</h1>
        <p class="page-lede">Questions, partnerships, tool listing inquiries, and editorial notes are welcome.</p>
      </div>
    </div>
  </section>

  <section class="section-shell-tight">
    <div class="container-full">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        <div class="editorial-panel">
          <p class="label">General</p>
          <h3 class="mt-3 font-display text-display-xs text-ink-950">General inquiries</h3>
          <p class="mt-3 text-sm text-ink-500">hello@aiforedu.ai</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Partnerships</p>
          <h3 class="mt-3 font-display text-display-xs text-ink-950">Commercial and strategic conversations</h3>
          <p class="mt-3 text-sm text-ink-500">partners@aiforedu.ai</p>
        </div>
        <div class="editorial-panel">
          <p class="label">Submissions</p>
          <h3 class="mt-3 font-display text-display-xs text-ink-950">List your tool for review</h3>
          <p class="mt-3 text-sm text-ink-500">Submit with context on privacy, use cases, and school fit.</p>
        </div>
      </div>

      <div class="cta-panel mt-10 max-w-3xl" x-data="{ name:'', email:'', subject:'general', role:'', organization:'', districtSize:'', buyingStage:'', message:'', sent:false, error:'', successTitle:'Message received', successMessage:'We will review it shortly.' }">
        <p class="section-label">Direct message</p>
        <h2 class="mt-3 font-display text-display-xs text-ink-950">Send a message</h2>
        <form class="mt-6 space-y-4" x-show="!sent"
          @submit.prevent="
            error = '';
            const res = await fetch('/api/contact', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name,email,subject,role,organization,districtSize,buyingStage,message}) });
            if (res.ok) {
              const d = await res.json();
              successTitle = d.successTitle || successTitle;
              successMessage = d.successMessage || successMessage;
              sent = true;
            } else { const d = await res.json(); error = d.error || 'Something went wrong'; }
          ">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label">Name</label>
              <input type="text" x-model="name" required class="input" />
            </div>
            <div>
              <label class="field-label">Email</label>
              <input type="email" x-model="email" required class="input" />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label">Role</label>
              <select x-model="role" class="select">
                <option value="">Select your role</option>
                <option value="superintendent">Superintendent</option>
                <option value="principal">Principal or school leader</option>
                <option value="district-innovation">District innovation lead</option>
                <option value="technology">Technology / IT leader</option>
                <option value="curriculum">Curriculum / instruction lead</option>
                <option value="teacher">Teacher</option>
                <option value="vendor">Vendor / partner</option>
              </select>
            </div>
            <div>
              <label class="field-label">Organization</label>
              <input type="text" x-model="organization" class="input" placeholder="District or school" />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label">District size</label>
              <select x-model="districtSize" class="select">
                <option value="">Select size</option>
                <option value="single-school">Single school</option>
                <option value="small-district">Small district</option>
                <option value="mid-size-district">Mid-size district</option>
                <option value="large-district">Large district</option>
                <option value="state-or-network">State / network</option>
              </select>
            </div>
            <div>
              <label class="field-label">Buying stage</label>
              <select x-model="buyingStage" class="select">
                <option value="">Select stage</option>
                <option value="exploring">Exploring</option>
                <option value="building-policy">Building policy</option>
                <option value="evaluating-tools">Evaluating tools</option>
                <option value="ready-to-buy">Ready to buy</option>
              </select>
            </div>
          </div>

          <div>
            <label class="field-label">Subject</label>
            <select x-model="subject" class="select">
              <option value="general">General Question</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="listing">List My Tool</option>
              <option value="advisory">Advisory / strategic support</option>
              <option value="feedback">Feedback</option>
            </select>
          </div>

          <div>
            <label class="field-label">Message</label>
            <textarea x-model="message" rows="5" required class="textarea"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">Send message</button>
          <p x-show="error" x-text="error" class="text-sm text-red-600"></p>
          <p class="small-note">Messages go to the editorial desk workflow. We only ask for the context needed to route and respond appropriately. See <a href="/privacy/" class="underline underline-offset-4">privacy</a>.</p>
        </form>
        <div x-show="sent" class="text-center py-8">
          <p class="section-label">Message sent</p>
          <p class="mt-3 font-display text-display-xs text-ink-950" x-text="successTitle">Thank you.</p>
          <p class="mt-2 text-ink-500" x-text="successMessage">We will review it shortly.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
