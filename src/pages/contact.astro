---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with the AIForEdu.ai team. Questions, partnerships, and listing inquiries welcome.">
  <section class="py-16">
    <div class="container-narrow">
      <h1 class="font-display text-4xl font-bold text-gray-900">Contact Us</h1>
      <p class="mt-3 text-lg text-gray-600">Have a question, partnership inquiry, or want to list your tool? We'd love to hear from you.</p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card text-center">
          <span class="text-3xl">📧</span>
          <h3 class="mt-3 font-semibold">General Inquiries</h3>
          <p class="mt-1 text-sm text-gray-600">hello@aiforedu.ai</p>
        </div>
        <div class="card text-center">
          <span class="text-3xl">🤝</span>
          <h3 class="mt-3 font-semibold">Partnerships</h3>
          <p class="mt-1 text-sm text-gray-600">partners@aiforedu.ai</p>
        </div>
        <div class="card text-center">
          <span class="text-3xl">📋</span>
          <h3 class="mt-3 font-semibold">List Your Tool</h3>
          <p class="mt-1 text-sm text-gray-600">Submit for review</p>
        </div>
      </div>

      <div class="mt-12 card max-w-xl mx-auto" x-data="{ name:'', email:'', subject:'', message:'', sent:false, error:'' }">
        <h2 class="font-display text-2xl font-bold text-gray-900">Send a Message</h2>
        <form class="mt-6 space-y-4" x-show="!sent"
          @submit.prevent="
            error = '';
            const res = await fetch('/api/contact', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name,email,subject,message}) });
            if (res.ok) sent = true; else { const d = await res.json(); error = d.error || 'Something went wrong'; }
          ">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <input type="text" x-model="name" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" x-model="email" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
            <select x-model="subject" class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500">
              <option value="general">General Question</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="listing">List My Tool</option>
              <option value="feedback">Feedback</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea x-model="message" rows="4" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">Send Message</button>
          <p x-show="error" x-text="error" class="text-sm text-red-600"></p>
        </form>
        <div x-show="sent" class="text-center py-8">
          <p class="text-2xl">✅</p>
          <p class="mt-2 font-display font-bold text-xl text-gray-900">Message Sent!</p>
          <p class="mt-1 text-gray-600">We typically respond within 24 hours.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
