---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description = 'The #1 AI-in-education library for K-12 school leaders. Unbiased tool reviews, policy templates, and practical guides.', ogImage = '/og-default.png', canonical } = Astro.props;
const fullTitle = title === 'Home' ? 'AIForEdu.ai — AI Tools, Policies & Guides for School Leaders' : `${title} | AIForEdu.ai`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:site_name" content="AIForEdu.ai" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#1a46f5" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <slot name="head" />
</head>
<body class="h-full flex flex-col">

  <!-- Navigation -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100/80" x-data="{ mobileOpen: false }">
    <nav class="container-wide flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 bg-gradient-to-br from-primary-600 to-primary-700 rounded-lg flex items-center justify-center shadow-sm">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
          </svg>
        </div>
        <span class="font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors">AIForEdu<span class="text-primary-600">.ai</span></span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        <a href="/tools/" class="btn-ghost text-sm">Tools</a>
        <a href="/compare/" class="btn-ghost text-sm">Compare</a>
        <a href="/policy/" class="btn-ghost text-sm">Policies</a>
        <a href="/guides/" class="btn-ghost text-sm">Guides</a>
        <a href="/products/" class="btn-ghost text-sm">Products</a>
        <div class="w-px h-6 bg-gray-200 mx-2"></div>
        <a href="/newsletter/" class="btn-primary text-sm !py-2 !px-4">Subscribe Free</a>
      </div>

      <button @click="mobileOpen = !mobileOpen" class="md:hidden p-2 -mr-2 text-gray-500 hover:text-gray-700 rounded-lg hover:bg-gray-100 transition-colors">
        <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" /></svg>
        <svg x-show="mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </nav>

    <div x-show="mobileOpen" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0 -translate-y-1" class="md:hidden bg-white border-t border-gray-100 shadow-lg">
      <div class="container-wide flex flex-col gap-1 py-4">
        <a href="/tools/" class="py-2.5 px-3 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">Tool Reviews</a>
        <a href="/compare/" class="py-2.5 px-3 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">Comparisons</a>
        <a href="/policy/" class="py-2.5 px-3 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">Policies</a>
        <a href="/guides/" class="py-2.5 px-3 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">Guides</a>
        <a href="/products/" class="py-2.5 px-3 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">Products</a>
        <div class="border-t border-gray-100 my-2"></div>
        <a href="/newsletter/" class="btn-primary text-sm text-center">Subscribe Free</a>
      </div>
    </div>
  </header>

  <div class="h-16"></div>

  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-950 text-gray-400">
    <div class="container-wide py-16">
      <div class="grid grid-cols-2 md:grid-cols-12 gap-8 md:gap-10">
        <div class="col-span-2 md:col-span-4">
          <a href="/" class="flex items-center gap-2.5">
            <div class="w-8 h-8 bg-gradient-to-br from-primary-500 to-primary-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
              </svg>
            </div>
            <span class="font-bold text-lg text-white">AIForEdu<span class="text-primary-400">.ai</span></span>
          </a>
          <p class="mt-4 text-sm leading-relaxed max-w-xs">The #1 independent AI-in-education library for K-12 school leaders.</p>
        </div>
        <div class="md:col-span-2">
          <h4 class="font-semibold text-white text-sm mb-4">Library</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/tools/" class="hover:text-white transition-colors">Tool Reviews</a></li>
            <li><a href="/compare/" class="hover:text-white transition-colors">Comparisons</a></li>
            <li><a href="/policy/" class="hover:text-white transition-colors">Policies</a></li>
            <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <h4 class="font-semibold text-white text-sm mb-4">Products</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/products/" class="hover:text-white transition-colors">AI Policy Kit</a></li>
            <li><a href="/products/" class="hover:text-white transition-colors">Readiness Workbook</a></li>
            <li><a href="/products/" class="hover:text-white transition-colors">Tool Vetting Pack</a></li>
            <li><a href="/newsletter/" class="hover:text-white transition-colors">Free Newsletter</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <h4 class="font-semibold text-white text-sm mb-4">Company</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
            <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
            <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy</a></li>
            <li><a href="/terms/" class="hover:text-white transition-colors">Terms</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <h4 class="font-semibold text-white text-sm mb-4">Connect</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="mailto:hello@aiforedu.ai" class="hover:text-white transition-colors">hello@aiforedu.ai</a></li>
            <li><a href="https://imglocal.com" class="hover:text-white transition-colors">Impact Glocal Inc.</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
        <p>&copy; {new Date().getFullYear()} Impact Glocal Inc. All rights reserved.</p>
        <p>Some links may earn a commission at no cost to you.</p>
      </div>
    </div>
  </footer>

  <script>
    import Alpine from 'alpinejs';
    window.Alpine = Alpine;
    Alpine.start();
  </script>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('is-visible');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
  </script>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>

  <script src="/pagefind/pagefind-ui.js" is:inline></script>
</body>
</html>
