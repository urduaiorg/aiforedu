---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description = 'The #1 AI-in-education library for K-12 school leaders. Unbiased tool reviews, policy templates, and practical guides.', ogImage = '/og-default.png', canonical } = Astro.props;
const fullTitle = title === 'Home' ? 'AIForEdu.ai — AI Tools, Policies & Guides for School Leaders' : `${title} | AIForEdu.ai`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:site_name" content="AIForEdu.ai" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#2563eb" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Pagefind -->
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

  <slot name="head" />
</head>
<body class="h-full flex flex-col bg-gray-50">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50" x-data="{ mobileOpen: false }">
    <nav class="container-wide flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🎓</span>
        <span class="font-display font-bold text-xl text-primary-700">AIForEdu<span class="text-accent-600">.ai</span></span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
        <a href="/tools/" class="hover:text-primary-600 transition-colors">Tool Reviews</a>
        <a href="/compare/" class="hover:text-primary-600 transition-colors">Comparisons</a>
        <a href="/policy/" class="hover:text-primary-600 transition-colors">Policies</a>
        <a href="/guides/" class="hover:text-primary-600 transition-colors">Guides</a>
        <a href="/products/" class="hover:text-primary-600 transition-colors">Products</a>
        <a href="/newsletter/" class="btn-primary text-sm !py-2 !px-4">Subscribe Free</a>
      </div>

      <!-- Mobile hamburger -->
      <button @click="mobileOpen = !mobileOpen" class="md:hidden p-2 text-gray-600">
        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg x-show="mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div x-show="mobileOpen" x-transition class="md:hidden bg-white border-t border-gray-100 pb-4">
      <div class="container-wide flex flex-col gap-3 pt-3 text-sm font-medium text-gray-600">
        <a href="/tools/" class="py-2 hover:text-primary-600">Tool Reviews</a>
        <a href="/compare/" class="py-2 hover:text-primary-600">Comparisons</a>
        <a href="/policy/" class="py-2 hover:text-primary-600">Policies</a>
        <a href="/guides/" class="py-2 hover:text-primary-600">Guides</a>
        <a href="/products/" class="py-2 hover:text-primary-600">Products</a>
        <a href="/newsletter/" class="btn-primary text-sm !py-2 text-center mt-2">Subscribe Free</a>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-gray-900 text-gray-400 mt-auto">
    <div class="container-wide py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div>
          <span class="font-display font-bold text-lg text-white">AIForEdu<span class="text-accent-400">.ai</span></span>
          <p class="mt-3 text-sm leading-relaxed">The #1 AI-in-education library for K-12 school leaders. Independent reviews, ready-to-use policies, and practical guides.</p>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Library</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/tools/" class="hover:text-white transition-colors">Tool Reviews</a></li>
            <li><a href="/compare/" class="hover:text-white transition-colors">Comparisons</a></li>
            <li><a href="/policy/" class="hover:text-white transition-colors">Policy Templates</a></li>
            <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Products</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/products/policy-kit/" class="hover:text-white transition-colors">AI Policy Kit — $29</a></li>
            <li><a href="/products/readiness-workbook/" class="hover:text-white transition-colors">Readiness Workbook — $19</a></li>
            <li><a href="/products/tool-vetting-pack/" class="hover:text-white transition-colors">Tool Vetting Pack — $39</a></li>
            <li><a href="/newsletter/" class="hover:text-white transition-colors">Free Newsletter</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Company</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
            <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
            <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a></li>
          </ul>
          <p class="mt-4 text-xs">A product of <a href="https://imglocal.com" class="text-accent-400 hover:text-accent-300">Impact Glocal Inc.</a></p>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-xs">
        <p>&copy; {new Date().getFullYear()} Impact Glocal Inc. All rights reserved.</p>
        <p class="mt-1">Affiliate disclosure: Some links earn us a commission at no extra cost to you.</p>
      </div>
    </div>
  </footer>

  <!-- Alpine.js -->
  <script>
    import Alpine from 'alpinejs';
    window.Alpine = Alpine;
    Alpine.start();
  </script>

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>

  <!-- Pagefind -->
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
</body>
</html>
